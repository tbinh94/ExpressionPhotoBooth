<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Top Bar -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/topBar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:paddingHorizontal="20dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivProfile"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_launcher_background"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <LinearLayout
            android:id="@+id/friendsBadge"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:background="@drawable/bg_handle"
            android:backgroundTint="#1A1A1A"
            android:gravity="center"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:src="@drawable/ic_arrow_back_24"
                app:tint="#FFFFFF"
                android:rotation="180"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="8 friends"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:fontFamily="sans-serif-medium"/>
        </LinearLayout>

        <ImageView
            android:id="@+id/btnChat"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="6dp"
            android:src="@drawable/ic_accent_bar"
            app:tint="#FFFFFF"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Camera Preview Area -->
    <androidx.cardview.widget.CardView
        android:id="@+id/previewCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="8dp"
        app:cardCornerRadius="48dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="#1A1A1A"
        app:layout_constraintDimensionRatio="4:5"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.camera.view.PreviewView
                android:id="@+id/viewFinder"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <!-- Flash Icon -->
            <ImageView
                android:id="@+id/btnFlash"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_margin="20dp"
                android:background="@drawable/bg_handle"
                android:backgroundTint="#40000000"
                android:padding="8dp"
                android:src="@drawable/ic_accent_bar"
                app:tint="#FFFFFF" />

            <!-- Mode Selector (Camera/Video) -->
            <LinearLayout
                android:id="@+id/modeSelector"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="24dp"
                android:background="@drawable/bg_handle"
                android:backgroundTint="#40000000"
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingHorizontal="4dp">

                <View
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_handle"
                    android:backgroundTint="#C9A96E" />

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:padding="6dp"
                    android:src="@drawable/ic_camera_switch"
                    app:tint="#FFFFFF" />
            </LinearLayout>

            <!-- Countdown overlay -->
            <TextView
                android:id="@+id/tvCountdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="sans-serif-black"
                android:text="3"
                android:textColor="#FFFFFF"
                android:textSize="80sp"
                android:visibility="gone" />

        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <!-- Ratio selection (Floating or hidden if not in image, keeping for functionality) -->
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/ratioContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <Button android:id="@+id/btnRatioSquare" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <Button android:id="@+id/btnRatioStandard" android:layout_width="wrap_content" android:layout_height="wrap_content" />
        <Button android:id="@+id/btnRatioWide" android:layout_width="wrap_content" android:layout_height="wrap_content" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- Bottom Controls -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomControls"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@id/tvHistory"
        app:layout_constraintTop_toBottomOf="@id/previewCard">

        <!-- Recent Preview Button (Left) -->
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/btnRecentPreview"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="12dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_gallery"
            android:background="#1A1A1A"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium"
            app:layout_constraintBottom_toBottomOf="@id/btnCapture"
            app:layout_constraintEnd_toStartOf="@id/btnCapture"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/btnCapture" />

        <ImageView
            android:id="@+id/ivRecentThumbnail"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Medium"
            app:layout_constraintBottom_toBottomOf="@id/btnRecentPreview"
            app:layout_constraintEnd_toEndOf="@id/btnRecentPreview"
            app:layout_constraintStart_toStartOf="@id/btnRecentPreview"
            app:layout_constraintTop_toTopOf="@id/btnRecentPreview" />

        <!-- Capture Button (Center) -->
        <View
            android:id="@+id/btnCapture"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:background="@drawable/bg_capture_button"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Switch Camera Button (Right) -->
        <ImageButton
            android:id="@+id/btnSwitchCamera"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:padding="10dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_camera_switch"
            app:tint="#FFFFFF"
            app:layout_constraintBottom_toBottomOf="@id/btnCapture"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.5"
            app:layout_constraintStart_toEndOf="@id/btnCapture"
            app:layout_constraintTop_toTopOf="@id/btnCapture" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- History Footer -->
    <TextView
        android:id="@+id/tvHistory"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="History"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <ImageView
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@drawable/ic_arrow_back_24"
        app:tint="#FFFFFF"
        android:rotation="270"
        app:layout_constraintTop_toBottomOf="@id/tvHistory"
        app:layout_constraintStart_toStartOf="@id/tvHistory"
        app:layout_constraintEnd_toEndOf="@id/tvHistory" />

</androidx.constraintlayout.widget.ConstraintLayout>