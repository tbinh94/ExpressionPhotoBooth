<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <!-- ═══════════════════════════════════════
         TOP APP BAR
    ═══════════════════════════════════════ -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topAppBar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@android:color/transparent"
        app:navigationIconTint="#2A5298"
        app:title="@string/title_camera"
        app:titleCentered="true"
        app:titleTextColor="#2A5298"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ═══════════════════════════════════════
         HEADER — Title + Subtitle
    ═══════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topAppBar">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/pacifico_regular"
            android:shadowColor="#FFFFFF"
            android:shadowRadius="8"
            android:text="Memories"
            android:textColor="#2A5298"
            android:textSize="32sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Elegant Capture Experience"
            android:textColor="#1F618D"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.08" />
    </LinearLayout>

    <!-- ═══════════════════════════════════════
         RATIO TOGGLE — pinned below header
    ═══════════════════════════════════════ -->
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/ratioContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        app:singleSelection="true"
        app:checkedButton="@+id/btnRatioSquare"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header">

        <Button
            android:id="@+id/btnRatioSquare"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="72dp"
            android:layout_height="36dp"
            android:text="1:1"
            android:textSize="12sp"
            android:textColor="#2A5298"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            app:strokeColor="#80FFFFFF" />

        <Button
            android:id="@+id/btnRatioStandard"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="72dp"
            android:layout_height="36dp"
            android:text="4:3"
            android:textSize="12sp"
            android:textColor="#2A5298"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            app:strokeColor="#80FFFFFF" />

        <Button
            android:id="@+id/btnRatioWide"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="72dp"
            android:layout_height="36dp"
            android:text="16:9"
            android:textSize="12sp"
            android:textColor="#2A5298"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            app:strokeColor="#80FFFFFF" />

    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- ═══════════════════════════════════════
         CAMERA PREVIEW CARD
         Constrained top ← ratioContainer
                      bottom → btnCapture
         Có margin đủ để không đụng nút Capture
    ═══════════════════════════════════════ -->
    <androidx.cardview.widget.CardView
        android:id="@+id/previewCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="20dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="6dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ratioContainer"
        app:layout_constraintBottom_toTopOf="@id/btnCapture"
        app:layout_constrainedHeight="true"
        app:layout_constrainedWidth="true">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.camera.view.PreviewView
                android:id="@+id/viewFinder"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#DCDFE2" />

            <!-- Countdown overlay -->
            <TextView
                android:id="@+id/tvCountdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="sans-serif-black"
                android:text="3"
                android:textColor="@android:color/white"
                android:textSize="96sp"
                android:visibility="gone"
                android:shadowColor="#99000000"
                android:shadowDx="0"
                android:shadowDy="4"
                android:shadowRadius="16" />

        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <!-- ═══════════════════════════════════════
         BOTTOM CONTROLS (CAPTURE & SWITCH & THUMBNAIL)
    ═══════════════════════════════════════ -->
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnCapture"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginBottom="24dp"
        android:background="@drawable/selector_camera_btn"
        android:elevation="6dp"
        android:stateListAnimator="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cvThumbnail"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="40dp"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        app:cardBackgroundColor="#E0E0E0"
        app:layout_constraintBottom_toBottomOf="@id/btnCapture"
        app:layout_constraintEnd_toStartOf="@id/btnCapture"
        app:layout_constraintTop_toTopOf="@id/btnCapture">

        <ImageView
            android:id="@+id/ivThumbnail"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop" />
    </androidx.cardview.widget.CardView>

    <ImageButton
        android:id="@+id/btnSwitchCamera"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="40dp"
        android:background="?selectableItemBackgroundBorderless"
        android:contentDescription="Switch Camera"
        android:src="@android:drawable/ic_popup_sync"
        app:tint="#2C3E50"
        app:layout_constraintBottom_toBottomOf="@id/btnCapture"
        app:layout_constraintStart_toEndOf="@id/btnCapture"
        app:layout_constraintTop_toTopOf="@id/btnCapture" />

    <!-- ═══════════════════════════════════════
         RESULT OVERLAY (hidden by default)
    ═══════════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutResult"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#D9FFFFFF"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="32dp"
        android:paddingBottom="32dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Select your best shot"
            android:textSize="26sp"
            android:fontFamily="@font/pacifico_regular"
            android:textColor="#2A5298"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap a photo to highlight it"
            android:textSize="12sp"
            android:textColor="#95A5A6"
            android:letterSpacing="0.06"
            android:layout_marginBottom="20dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvPhotos"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNextToEdit"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:layout_marginTop="20dp"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.10"
            android:text="Next to Edit"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="#2A5298"
            app:cornerRadius="27dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>