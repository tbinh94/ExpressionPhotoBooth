<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg">

    <!-- ── FULL SCREEN SCAN MODE (HIDDEN BY DEFAULT) ── -->
    <androidx.camera.view.PreviewView
        android:id="@+id/viewFinderFull"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone" />

    <ImageView
        android:id="@+id/cameraFrameOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="20dp"
        android:src="@drawable/camera_frame"
        android:visibility="gone"
        android:elevation="50dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintDimensionRatio="4:5"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.9" />

    <ImageView
        android:id="@+id/bgGradient"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_screen_dynamic"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- ── TOP BAR (GROUPED FOR EASY HIDING) ── -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/setupControlsGroup"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/topAppBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            app:title=""
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Title -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/camera_title_margin_top"
            android:fontFamily="@font/pacifico_regular"
            android:text="@string/camera_main_title"
            android:textColor="@color/screen_title"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/topAppBar" />

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/camera_subtitle_margin_top"
            android:text="@string/camera_header_subtitle"
            android:textColor="@color/screen_subtitle"
            android:textSize="13sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTitle" />

        <!-- ── PREVIEW CARD ── -->
        <androidx.cardview.widget.CardView
            android:id="@+id/previewCard"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="@dimen/camera_preview_horizontal_margin"
            android:layout_marginTop="@dimen/camera_preview_margin_top"
            android:layout_marginEnd="@dimen/camera_preview_horizontal_margin"
            app:cardCornerRadius="24dp"
            app:cardElevation="10dp"
            app:layout_constrainedHeight="true"
            app:layout_constraintDimensionRatio="1:1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHeight_max="@dimen/camera_preview_max_height"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
            app:layout_constraintBottom_toTopOf="@id/controlsBlock">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <androidx.camera.view.PreviewView
                    android:id="@+id/viewFinder"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <TextView
                    android:id="@+id/tvCountdown"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|start"
                    android:layout_margin="16dp"
                    android:fontFamily="sans-serif-black"
                    android:text="@string/capture_countdown_default"
                    android:textColor="@android:color/white"
                    android:textSize="64sp"
                    android:shadowColor="#80000000"
                    android:shadowDx="4"
                    android:shadowDy="4"
                    android:shadowRadius="15"
                    android:visibility="gone" />

                <com.example.expressionphotobooth.AiOverlayView
                    android:id="@+id/overlayView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <ImageButton
                    android:id="@+id/btnSwitchCamera"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_gravity="top|end"
                    android:layout_margin="10dp"
                    android:background="@drawable/bg_flash_pill"
                    android:elevation="4dp"
                    android:padding="10dp"
                    android:src="@drawable/ic_flip_camera"
                    android:contentDescription="@string/camera_switch_lens"
                    app:tint="@color/screen_icon_tint" />

                <ImageButton
                    android:id="@+id/btnPortraitMode"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_gravity="top|start"
                    android:layout_margin="10dp"
                    android:background="@drawable/bg_flash_pill"
                    android:elevation="4dp"
                    android:padding="10dp"
                    android:src="@drawable/ic_person_24"
                    android:contentDescription="@string/main_portrait_mode"
                    app:tint="@color/screen_icon_tint" />
            </FrameLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── CONTROLS BLOCK ── -->
        <LinearLayout
            android:id="@+id/controlsBlock"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/camera_controls_horizontal_margin"
            android:layout_marginTop="@dimen/camera_controls_margin_top"
            android:layout_marginEnd="@dimen/camera_controls_horizontal_margin"
            android:orientation="vertical"
            app:layout_constraintBottom_toTopOf="@id/btnCapture"
            android:layout_marginBottom="@dimen/camera_controls_margin_bottom"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/previewCard">

            <!-- Label -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:text="@string/main_capture_mode_label"
                android:textColor="@color/screen_subtitle"
                android:textSize="11sp"
                android:letterSpacing="0.08"
                android:textStyle="bold" />

            <!-- Mode toggle: Tự động / AI Detect — dạng segment rõ ràng -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_toggle_group"
                android:padding="4dp">

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/modeContainer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    app:checkedButton="@+id/btnModeCountdown">

                    <Button
                        android:id="@+id/btnModeCountdown"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="@string/main_mode_auto"
                        android:textAllCaps="true"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/selector_mode_text"
                        app:backgroundTint="@color/selector_mode_bg"
                        app:cornerRadius="20dp"
                        app:strokeWidth="0dp" />

                    <Button
                        android:id="@+id/btnModeExpression"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="@string/main_mode_ai_detect"
                        android:textAllCaps="true"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/selector_mode_text"
                        app:backgroundTint="@color/selector_mode_bg"
                        app:cornerRadius="20dp"
                        app:strokeWidth="0dp" />
                </com.google.android.material.button.MaterialButtonToggleGroup>
            </FrameLayout>

            <!-- AI sub-toggle: scrollable carousel centered -->
            <HorizontalScrollView
                android:id="@+id/aiScrollContainer"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="10dp"
                android:visibility="gone"
                android:scrollbars="none"
                android:overScrollMode="never"
                android:fillViewport="true">

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/aiSelectionContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:gravity="center"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    app:checkedButton="@+id/btnAiFace"
                    app:strokeWidth="0dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAiFace"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:minWidth="90dp"
                        android:text="😊 FACE"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/selector_ai_btn_text"
                        app:backgroundTint="@color/selector_ai_btn_bg"
                        app:cornerRadius="19dp"
                        app:strokeWidth="0dp"
                        android:layout_marginEnd="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAiHand"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:minWidth="100dp"
                        android:text="✋ GESTURE"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/selector_ai_btn_text"
                        app:backgroundTint="@color/selector_ai_btn_bg"
                        app:cornerRadius="19dp"
                        app:strokeWidth="0dp"
                        android:layout_marginEnd="8dp" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAiVoice"
                        style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="38dp"
                        android:minWidth="90dp"
                        android:text="🎤 VOICE"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:textColor="@color/selector_ai_btn_text"
                        app:backgroundTint="@color/selector_ai_btn_bg"
                        app:cornerRadius="19dp"
                        app:strokeWidth="0dp" />

                </com.google.android.material.button.MaterialButtonToggleGroup>
            </HorizontalScrollView>

            <!-- Centered Ratio Status + Dot counter -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp"
                android:gravity="center"
                android:orientation="horizontal">
                <LinearLayout
                    android:id="@+id/dotContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingEnd="8dp"
                    android:gravity="center_vertical" />
                <TextView
                    android:id="@+id/tvCaptureStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/capture_status_ready"
                    android:textColor="@color/screen_title"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>

        </LinearLayout>

        <!-- Sound - left of capture -->
        <ImageButton
            android:id="@+id/btnSound"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginEnd="@dimen/camera_side_button_margin_start"
            android:background="@drawable/bg_flash_pill"
            android:src="@drawable/ic_sound_on"
            android:contentDescription="@string/main_sound_toggle"
            android:padding="14dp"
            app:tint="@color/screen_icon_tint"
            app:layout_constraintBottom_toBottomOf="@id/btnCapture"
            app:layout_constraintEnd_toStartOf="@id/btnCapture"
            app:layout_constraintTop_toTopOf="@id/btnCapture" />
        <!-- Capture button -->
        <ImageButton
            android:id="@+id/btnCapture"
            android:layout_width="84dp"
            android:layout_height="84dp"
            android:layout_marginBottom="@dimen/camera_capture_bottom_margin"
            android:background="@drawable/selector_camera_btn"
            android:contentDescription="@string/capture_photo"
            android:elevation="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
        <!-- Flash - right of capture -->
        <ImageButton
            android:id="@+id/btnFlash"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginStart="@dimen/camera_side_button_margin_start"
            android:background="@drawable/bg_flash_pill"
            android:src="@drawable/ic_flash_off_24"
            android:contentDescription="@string/camera_flash_toggle"
            android:padding="14dp"
            app:tint="@color/screen_icon_tint"
            app:layout_constraintBottom_toBottomOf="@id/btnCapture"
            app:layout_constraintStart_toEndOf="@id/btnCapture"
            app:layout_constraintTop_toTopOf="@id/btnCapture" />
        <!-- Last capture thumbnail -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardLastCapture"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:layout_marginStart="24dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:layout_constraintBottom_toBottomOf="@id/btnCapture"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@id/btnCapture">

            <ImageView
                android:id="@+id/ivLastCapturePreview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop" />
        </androidx.cardview.widget.CardView>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Flash overlay -->
    <View
        android:id="@+id/captureFlashOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/white"
        android:visibility="gone"
        android:elevation="100dp" />

</androidx.constraintlayout.widget.ConstraintLayout>


