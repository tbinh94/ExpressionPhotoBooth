<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background -->
    <ImageView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_gradient"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Top Bar -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:title=""
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Nút Quay lại (Legacy, kept for reference but usually handled by topAppBar) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBack"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="36dp"
        android:insetLeft="0dp"
        android:insetTop="0dp"
        android:insetRight="0dp"
        android:insetBottom="0dp"
        android:visibility="gone"
        app:icon="@drawable/ic_arrow_back_24"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconSize="24dp"
        app:iconTint="#2A5298"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.MaterialComponents.SmallComponent"
        app:cornerRadius="24dp" />

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:fontFamily="@font/pacifico_regular"
        android:shadowColor="#FFFFFF"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="8"
        android:text="@string/camera_main_title"
        android:textColor="#2A5298"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.465"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topAppBar" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/camera_subtitle_margin_top"
        android:text="@string/camera_header_subtitle"
        android:textColor="#1F618D"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle" />

    <!-- Khung Camera chính -->
    <androidx.cardview.widget.CardView
        android:id="@+id/previewCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="@dimen/camera_preview_horizontal_margin"
        android:layout_marginTop="@dimen/camera_preview_margin_top"
        android:layout_marginEnd="@dimen/camera_preview_horizontal_margin"
        app:cardCornerRadius="24dp"
        app:cardElevation="12dp"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <androidx.camera.view.PreviewView
                android:id="@+id/viewFinder"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <TextView
                android:id="@+id/tvCountdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:fontFamily="sans-serif-black"
                android:text="@string/capture_countdown_default"
                android:textColor="@android:color/white"
                android:textSize="120sp"
                android:visibility="gone"
                android:shadowColor="#80000000"
                android:shadowDx="4"
                android:shadowDy="4"
                android:shadowRadius="15"/>

            <!-- Khung vẽ debbuging AI -->
            <com.example.expressionphotobooth.AiOverlayView
                android:id="@+id/overlayView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="visible" />

            <!-- Nút Switch Camera (Inside frame) -->
            <ImageButton
                android:id="@+id/btnSwitchCamera"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="top|end"
                android:layout_margin="12dp"
                android:background="@drawable/bg_flash_pill"
                android:elevation="4dp"
                android:padding="10dp"
                android:src="@drawable/ic_flip_camera"
                android:contentDescription="@string/camera_switch_lens"
                app:tint="#2A5298" />
        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <!-- Nút chọn tỉ lệ -->
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/ratioContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/camera_ratio_margin_top"
        app:singleSelection="true"
        app:checkedButton="@+id/btnRatioSquare"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/previewCard">

        <Button
            android:id="@+id/btnRatioSquare"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ratio_square"
            android:textColor="#2A5298"
            app:strokeColor="#2A5298" />

        <Button
            android:id="@+id/btnRatioWide"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/ratio_wide"
            android:textColor="#2A5298"
            app:strokeColor="#2A5298" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- Nút chọn chế độ chụp -->
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/modeContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:singleSelection="true"
        app:checkedButton="@+id/btnModeCountdown"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ratioContainer">

        <Button
            android:id="@+id/btnModeCountdown"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tự động"
            android:textColor="#2A5298"
            app:strokeColor="#2A5298" />

        <Button
            android:id="@+id/btnModeExpression"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AI Detect"
            android:textColor="#2A5298"
            app:strokeColor="#2A5298" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- Thêm chọn Face hoặc Gesture -->
    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/aiSelectionContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:visibility="gone"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:checkedButton="@+id/btnAiFace"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/modeContainer">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAiFace"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🙂 Khuôn mặt"
            android:textColor="@color/selector_ai_btn_text"
            android:backgroundTint="@color/selector_ai_btn_bg"
            android:textSize="12sp"
            app:strokeColor="#2A5298" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAiHand"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✌️ Hành động"
            android:textColor="@color/selector_ai_btn_text"
            android:backgroundTint="@color/selector_ai_btn_bg"
            android:textSize="12sp"
            app:strokeColor="#2A5298" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- Status & Progress -->
    <TextView
        android:id="@+id/tvCaptureStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/capture_status_ready"
        android:textColor="#2A5298"
        android:textSize="14sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/aiSelectionContainer" />

    <LinearLayout
        android:id="@+id/dotContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/camera_dot_margin_top"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvCaptureStatus" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/captureProgress"
        android:layout_width="@dimen/camera_progress_width"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/camera_progress_margin_top"
        app:indicatorColor="#2A5298"
        app:trackColor="#D1D9E6"
        app:trackThickness="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dotContainer" />


    <!-- Nút Flash -->
    <ImageButton
        android:id="@+id/btnFlash"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="16dp"
        android:background="@drawable/bg_flash_pill"
        android:src="@drawable/ic_flash_off_24"
        android:contentDescription="@string/camera_flash_toggle"
        android:padding="12dp"
        app:tint="#2A5298"
        app:layout_constraintBottom_toBottomOf="@id/btnCapture"
        app:layout_constraintStart_toEndOf="@id/btnCapture"
        app:layout_constraintTop_toTopOf="@id/btnCapture" />

    <!-- Nút Sound -->
    <ImageButton
        android:id="@+id/btnSound"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_flash_pill"
        android:src="@drawable/ic_sound_on"
        android:contentDescription="Bật/Tắt âm thanh"
        android:padding="12dp"
        app:tint="#2A5298"
        app:layout_constraintBottom_toBottomOf="@id/btnCapture"
        app:layout_constraintStart_toEndOf="@id/btnFlash"
        app:layout_constraintTop_toTopOf="@id/btnCapture" />

    <!-- Nút Capture -->
    <ImageButton
        android:id="@+id/btnCapture"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginBottom="@dimen/camera_capture_bottom_margin"
        android:background="@drawable/selector_camera_btn"
        android:contentDescription="@string/capture_photo"
        android:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Last Capture Preview -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardLastCapture"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_marginEnd="16dp"
        android:visibility="gone"
        app:cardCornerRadius="12dp"
        app:cardElevation="6dp"
        app:layout_constraintBottom_toBottomOf="@id/btnCapture"
        app:layout_constraintEnd_toStartOf="@id/btnCapture"
        app:layout_constraintTop_toTopOf="@id/btnCapture">
        <ImageView
            android:id="@+id/ivLastCapturePreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop" />
    </androidx.cardview.widget.CardView>

    <!-- Flash Overlay -->
    <View
        android:id="@+id/captureFlashOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/white"
        android:visibility="gone"
        android:elevation="100dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
