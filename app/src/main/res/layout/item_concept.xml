<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/setup_concept_padding_horizontal"
    android:paddingTop="@dimen/setup_concept_padding_top">

    <TextView
        android:id="@+id/tvConceptName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/item_concept_placeholder"
        android:textColor="#1A5276"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="@dimen/setup_concept_title_margin_bottom" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvFrames"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical" />
</LinearLayout>