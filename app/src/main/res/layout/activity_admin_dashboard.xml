<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/admin_dashboard_bg">

    <androidx.coordinatorlayout.widget.CoordinatorLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.google.android.material.appbar.AppBarLayout
            android:id="@+id/appBarLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/admin_dashboard_bg"
            app:elevation="0dp">

            <com.google.android.material.appbar.CollapsingToolbarLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingBottom="20dp">

                    <!-- Header: Admin Info - Adjusted layout and padding to avoid cut-off -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="@dimen/admin_header_padding_horizontal"
                        android:paddingTop="@dimen/admin_header_padding_top"
                        android:paddingBottom="@dimen/admin_header_padding_bottom">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnMenu"
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:insetLeft="0dp"
                            android:insetTop="0dp"
                            android:insetRight="0dp"
                            android:insetBottom="0dp"
                            android:minWidth="0dp"
                            android:minHeight="0dp"
                            android:padding="0dp"
                            android:gravity="center"
                            app:backgroundTint="@android:color/transparent"
                            app:cornerRadius="12dp"
                            app:icon="@drawable/ic_menu_24"
                            app:iconGravity="textStart"
                            app:iconPadding="0dp"
                            app:iconSize="24dp"
                            app:iconTint="@color/white" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:layout_marginStart="16dp"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvAdminGreeting"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/admin_dashboard_greeting"
                                android:textColor="@color/white"
                                android:alpha="0.8"
                                android:textSize="14sp" />

                             <TextView
                                 android:layout_width="wrap_content"
                                 android:layout_height="wrap_content"
                                 android:text="@string/admin_role_label"
                                 android:textColor="@color/white"
                                 android:textSize="12sp"
                                 android:textStyle="bold" />
                        </LinearLayout>

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/btnThemeToggle"
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:src="@drawable/ic_theme_sun_20"
                            android:scaleType="center"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackgroundBorderless"
                            android:layout_marginStart="8dp"
                            app:shapeAppearanceOverlay="@style/CircleAppearance"
                            app:strokeColor="@color/app_blue"
                            app:strokeWidth="1dp"
                            app:tint="@color/white" />

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/btnLanguageToggle"
                            android:layout_width="38dp"
                            android:layout_height="38dp"
                            android:src="@drawable/ic_flag_vn"
                            android:scaleType="centerCrop"
                            android:clickable="true"
                            android:focusable="true"
                            android:foreground="?attr/selectableItemBackgroundBorderless"
                            android:layout_marginStart="8dp"
                            app:shapeAppearanceOverlay="@style/CircleAppearance"
                            app:strokeColor="@color/app_blue"
                            app:strokeWidth="1dp" />

                    </LinearLayout>

                    <!-- Stat Cards Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:paddingHorizontal="@dimen/admin_stats_padding_horizontal"
                        android:clipToPadding="false"
                        android:paddingBottom="8dp"
                        android:weightSum="3">

                        <!-- Card 1: Accounts -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardStatAccounts"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="@dimen/admin_stat_card_spacing"
                            android:layout_weight="1"
                            android:minHeight="@dimen/admin_stat_card_min_height"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardBackgroundColor="@android:color/transparent"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="4dp"
                            app:rippleColor="#33FFFFFF"
                            app:strokeWidth="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/shape_stat_card_blue"
                                android:orientation="vertical"
                                android:padding="@dimen/admin_stat_card_padding">

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="36dp"
                                    android:layout_height="36dp"
                                    app:cardBackgroundColor="#33FFFFFF"
                                    app:cardCornerRadius="18dp"
                                    app:cardElevation="0dp"
                                    app:strokeWidth="0dp"
                                    android:layout_marginBottom="8dp">

                                    <ImageView
                                        android:layout_width="20dp"
                                        android:layout_height="20dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_person_24"
                                        app:tint="@color/white"/>
                                </com.google.android.material.card.MaterialCardView>

                                <TextView
                                    android:id="@+id/tvStatTotalAccounts"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="@color/white"
                                    android:textSize="@dimen/admin_stat_value_text"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvStatAccountsLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:minLines="2"
                                    android:maxLines="2"
                                    android:text="@string/admin_stat_accounts"
                                    android:textColor="#E6FFFFFF"
                                    android:textSize="@dimen/admin_stat_label_text" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Card 2: Image downloads -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardStatImageDownloads"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="@dimen/admin_stat_card_spacing"
                            android:layout_weight="1"
                            android:minHeight="@dimen/admin_stat_card_min_height"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardBackgroundColor="@android:color/transparent"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="4dp"
                            app:rippleColor="#33FFFFFF"
                            app:strokeWidth="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/shape_stat_card_gold"
                                android:orientation="vertical"
                                android:padding="@dimen/admin_stat_card_padding">

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="36dp"
                                    android:layout_height="36dp"
                                    app:cardBackgroundColor="#33FFFFFF"
                                    app:cardCornerRadius="18dp"
                                    app:cardElevation="0dp"
                                    app:strokeWidth="0dp"
                                    android:layout_marginBottom="8dp">

                                    <ImageView
                                        android:layout_width="20dp"
                                        android:layout_height="20dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_download_24"
                                        app:tint="@color/white"/>
                                </com.google.android.material.card.MaterialCardView>

                                <TextView
                                    android:id="@+id/tvStatImageDownloads"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="@color/white"
                                    android:textSize="@dimen/admin_stat_value_text"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvStatImageDownloadsLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:minLines="2"
                                    android:maxLines="2"
                                    android:text="@string/admin_stat_image_downloads"
                                    android:textColor="#E6FFFFFF"
                                    android:textSize="@dimen/admin_stat_label_text" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>

                        <!-- Card 3: Video downloads -->
                        <com.google.android.material.card.MaterialCardView
                            android:id="@+id/cardStatVideoDownloads"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/admin_stat_card_spacing"
                            android:layout_weight="1"
                            android:minHeight="@dimen/admin_stat_card_min_height"
                            android:clickable="true"
                            android:focusable="true"
                            app:cardBackgroundColor="@android:color/transparent"
                            app:cardCornerRadius="16dp"
                            app:cardElevation="4dp"
                            app:rippleColor="#33FFFFFF"
                            app:strokeWidth="0dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:background="@drawable/shape_stat_card_red"
                                android:orientation="vertical"
                                android:padding="@dimen/admin_stat_card_padding">

                                <com.google.android.material.card.MaterialCardView
                                    android:layout_width="36dp"
                                    android:layout_height="36dp"
                                    app:cardBackgroundColor="#33FFFFFF"
                                    app:cardCornerRadius="18dp"
                                    app:cardElevation="0dp"
                                    app:strokeWidth="0dp"
                                    android:layout_marginBottom="8dp">

                                    <ImageView
                                        android:layout_width="20dp"
                                        android:layout_height="20dp"
                                        android:layout_gravity="center"
                                        android:src="@drawable/ic_videocam_24"
                                        app:tint="@color/white"/>
                                </com.google.android.material.card.MaterialCardView>

                                <TextView
                                    android:id="@+id/tvStatVideoDownloads"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textColor="@color/white"
                                    android:textSize="@dimen/admin_stat_value_text"
                                    android:textStyle="bold" />

                                <TextView
                                    android:id="@+id/tvStatVideoDownloadsLabel"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="2dp"
                                    android:minLines="2"
                                    android:maxLines="2"
                                    android:text="@string/admin_stat_video_downloads"
                                    android:textColor="#E6FFFFFF"
                                    android:textSize="@dimen/admin_stat_label_text" />
                            </LinearLayout>
                        </com.google.android.material.card.MaterialCardView>
                    </LinearLayout>
                </LinearLayout>

            </com.google.android.material.appbar.CollapsingToolbarLayout>

        </com.google.android.material.appbar.AppBarLayout>

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPager"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    </androidx.coordinatorlayout.widget.CoordinatorLayout>

    <!-- ── NAVIGATION DRAWER ── -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="@dimen/admin_nav_drawer_width"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@drawable/bg_admin_nav_gradient"
        android:fitsSystemWindows="true"
        app:headerLayout="@layout/nav_header_admin"
        app:menu="@menu/admin_drawer_menu"
        app:itemIconTint="@color/nav_item_icon_tint"
        app:itemTextColor="@color/nav_item_text_color"
        app:itemRippleColor="@color/nav_item_ripple"
        app:itemShapeFillColor="@color/nav_item_shape_fill"
        app:itemShapeAppearanceOverlay="@style/NavItemShape"
        app:itemTextAppearance="@style/TextAppearance.AdminNavItem"
        app:itemIconSize="@dimen/admin_nav_icon_size"
        app:itemMaxLines="1"
        app:itemIconPadding="@dimen/admin_nav_item_icon_padding"
        app:itemHorizontalPadding="@dimen/admin_nav_item_horizontal_padding"
        app:itemVerticalPadding="@dimen/admin_nav_item_vertical_padding"
        app:itemShapeInsetStart="@dimen/admin_nav_item_inset_horizontal"
        app:itemShapeInsetEnd="@dimen/admin_nav_item_inset_horizontal"
        app:itemShapeInsetTop="@dimen/admin_nav_item_inset_vertical"
        app:itemShapeInsetBottom="@dimen/admin_nav_item_inset_vertical" />

</androidx.drawerlayout.widget.DrawerLayout>

