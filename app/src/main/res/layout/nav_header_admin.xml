<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/transparent"
    android:paddingHorizontal="@dimen/admin_nav_header_padding_horizontal"
    android:paddingTop="@dimen/admin_nav_header_padding_top"
    android:paddingBottom="@dimen/admin_nav_header_padding_bottom">

    <!-- Logo + App name row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:baselineAligned="false"
        android:layout_marginBottom="@dimen/admin_nav_header_logo_gap">

        <!-- App icon box -->
        <FrameLayout
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/shape_nav_icon_box">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_menu_24"
                app:tint="#FFFFFF"
                android:contentDescription="@string/admin_nav_logo_desc" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/admin_nav_title"
                android:textColor="#FFFFFF"
                android:textSize="17sp"
                android:textStyle="bold"
                android:letterSpacing="0.02" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/admin_nav_version"
                android:textColor="#7E97CC"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <!-- User card -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/shape_nav_user_card"
        android:paddingHorizontal="12dp"
        android:paddingVertical="13dp"
        android:layout_marginBottom="6dp">

        <!-- Avatar circle -->
        <FrameLayout
            android:layout_width="46dp"
            android:layout_height="46dp"
            android:background="@drawable/shape_nav_avatar">

            <TextView
                android:id="@+id/tvNavAvatarInitials"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/admin_nav_avatar_initials"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- Email + role -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNavHeaderSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/admin_email_fallback"
                android:textColor="#E8EFFF"
                android:textSize="15sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:maxLines="1" />

            <!-- Online dot + role -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="2dp">

                <View
                    android:layout_width="6dp"
                    android:layout_height="6dp"
                    android:background="@drawable/shape_online_dot" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="5dp"
                    android:background="@drawable/bg_nav_role_pill"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:text="@string/admin_nav_role"
                    android:textColor="#9EC0FF"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Chevron -->
        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_arrow_forward_24"
            app:tint="#5778C8"
            android:alpha="0.8"
            android:contentDescription="@string/admin_nav_next_desc" />
    </LinearLayout>

</LinearLayout>
