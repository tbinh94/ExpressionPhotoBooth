<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/history_item_card_margin_bottom"
    app:cardBackgroundColor="@color/history_card_surface"
    app:cardCornerRadius="@dimen/history_item_card_corner_radius"
    app:cardElevation="@dimen/history_item_card_elevation"
    app:strokeColor="@color/history_card_stroke"
    app:strokeWidth="@dimen/history_item_card_stroke_width">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="@dimen/history_item_content_padding">

        <ImageView
            android:id="@+id/ivHistoryThumb"
            android:layout_width="@dimen/history_item_thumb_width"
            android:layout_height="@dimen/history_item_thumb_height"
            android:background="@drawable/bg_rounded_white"
            android:padding="@dimen/history_item_thumb_padding"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/history_item_content_gap"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvHistoryDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/history_primary_text"
                android:textSize="@dimen/history_meta_text_size"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvHistoryFrame"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/history_item_meta_gap_small"
                android:textColor="@color/history_primary_text"
                android:textSize="@dimen/history_meta_text_size"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvHistoryVideoState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/history_item_meta_gap_small"
                android:textColor="@color/history_primary_text"
                android:textSize="@dimen/history_submeta_text_size" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/history_item_row_gap"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnHistorySavePhoto"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/history_pill_height"
                    android:layout_weight="1"
                    android:text="@string/history_save_photo"
                    android:textAllCaps="false"
                    android:textColor="@android:color/black"
                    android:textSize="@dimen/history_pill_text_size"
                    android:textStyle="bold"
                    app:backgroundTint="@color/history_pill_pink"
                    app:cornerRadius="@dimen/history_pill_corner_radius" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnHistoryReload"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/history_pill_height"
                    android:layout_marginStart="@dimen/history_item_button_gap"
                    android:layout_weight="1"
                    android:text="@string/history_reload"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="@dimen/history_pill_text_size"
                    android:textStyle="bold"
                    app:backgroundTint="@color/history_primary_text"
                    app:cornerRadius="@dimen/history_pill_corner_radius" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/history_item_button_gap"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnHistorySaveVideo"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/history_pill_height"
                    android:layout_weight="1"
                    android:text="@string/history_save_video"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="@dimen/history_pill_text_size"
                    android:textStyle="bold"
                    app:backgroundTint="@color/history_primary_text"
                    app:cornerRadius="@dimen/history_pill_corner_radius" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnHistoryShare"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/history_pill_height"
                    android:layout_marginStart="@dimen/history_item_button_gap"
                    android:layout_weight="1"
                    android:text="@string/result_share"
                    android:textAllCaps="false"
                    android:textColor="@android:color/black"
                    android:textSize="@dimen/history_pill_text_size"
                    android:textStyle="bold"
                    app:backgroundTint="@color/history_pill_pink"
                    app:cornerRadius="@dimen/history_pill_corner_radius" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHistoryFeedback"
                android:layout_width="match_parent"
                android:layout_height="@dimen/history_pill_height"
                android:layout_marginTop="@dimen/history_item_button_gap"
                android:text="@string/history_view_feedback"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="@dimen/history_pill_text_size"
                android:textStyle="bold"
                app:backgroundTint="@color/history_primary_text"
                app:cornerRadius="@dimen/history_pill_corner_radius" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHistoryDelete"
                android:layout_width="match_parent"
                android:layout_height="@dimen/history_pill_height"
                android:layout_marginTop="@dimen/history_item_button_gap"
                android:text="@string/history_delete"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="@dimen/history_pill_text_size"
                android:textStyle="bold"
                app:backgroundTint="@color/history_danger"
                app:cornerRadius="@dimen/history_pill_corner_radius" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

