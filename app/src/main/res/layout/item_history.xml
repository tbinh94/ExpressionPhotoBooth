<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardBackgroundColor="#73FFFFFF"
    app:cardCornerRadius="18dp"
    app:cardElevation="2dp"
    app:strokeColor="#443A57C4"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp">

        <ImageView
            android:id="@+id/ivHistoryThumb"
            android:layout_width="124dp"
            android:layout_height="212dp"
            android:background="@drawable/bg_rounded_white"
            android:padding="2dp"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvHistoryDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#2A4EA1"
                android:textSize="@dimen/history_meta_text_size"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvHistoryFrame"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textColor="#2A4EA1"
                android:textSize="@dimen/history_meta_text_size"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvHistoryVideoState"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textColor="#2A4EA1"
                android:textSize="@dimen/history_submeta_text_size" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnHistorySavePhoto"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/history_pill_height"
                    android:layout_weight="1"
                    android:text="@string/history_save_photo"
                    android:textAllCaps="false"
                    android:textColor="#000000"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:backgroundTint="#F7A9D5"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnHistoryReload"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/history_pill_height"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:text="@string/history_reload"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:backgroundTint="#2A4EA1"
                    app:cornerRadius="18dp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnHistorySaveVideo"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/history_pill_height"
                    android:layout_weight="1"
                    android:text="@string/history_save_video"
                    android:textAllCaps="false"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:backgroundTint="#2A4EA1"
                    app:cornerRadius="18dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnHistoryShare"
                    android:layout_width="0dp"
                    android:layout_height="@dimen/history_pill_height"
                    android:layout_marginStart="6dp"
                    android:layout_weight="1"
                    android:text="@string/result_share"
                    android:textAllCaps="false"
                    android:textColor="#000000"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:backgroundTint="#F7A9D5"
                    app:cornerRadius="18dp" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHistoryFeedback"
                android:layout_width="match_parent"
                android:layout_height="@dimen/history_pill_height"
                android:layout_marginTop="6dp"
                android:text="@string/history_view_feedback"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                app:backgroundTint="#2A4EA1"
                app:cornerRadius="18dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHistoryDelete"
                android:layout_width="match_parent"
                android:layout_height="@dimen/history_pill_height"
                android:layout_marginTop="6dp"
                android:text="@string/history_delete"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                app:backgroundTint="#FF3D3D"
                app:cornerRadius="18dp" />
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

