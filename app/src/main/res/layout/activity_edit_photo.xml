<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <!-- ── TOP APP BAR ── -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:background="@android:color/transparent"
        app:contentInsetStart="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingEnd="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:insetBottom="0dp"
                android:insetTop="0dp"
                android:text=""
                app:icon="@drawable/ic_arrow_back_24"
                app:iconGravity="textStart"
                app:iconSize="22dp"
                app:iconTint="#2A5298" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/pacifico_regular"
                android:text="@string/title_edit"
                android:textColor="#2A5298"
                android:textSize="20sp" />


            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCompare"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:insetBottom="0dp"
                android:insetTop="0dp"
                android:text=""
                app:icon="@drawable/ic_visibility_24"
                app:iconGravity="textStart"
                app:iconSize="20dp"
                app:iconTint="#2A5298" />

        </LinearLayout>
    </com.google.android.material.appbar.MaterialToolbar>

    <!-- ── PHOTO PREVIEW CARD ── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/photoPreviewCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="24dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="10dp"
        app:layout_constraintBottom_toTopOf="@id/editPanelCard"
        app:layout_constraintDimensionRatio="3:4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintVertical_bias="0.0"
        app:layout_constraintHeight_max="360dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/ivEditingPhoto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#E8EDF5"
                android:scaleType="centerCrop" />

            <!-- Active edit chip, floats top-right -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chipActiveEdit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="10dp"
                android:text="Original"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                app:chipBackgroundColor="#88000000"
                app:chipMinHeight="24dp"
                app:chipStrokeWidth="0dp" />

        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <!-- ── BOTTOM EDIT PANEL ── -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/editPanelCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="0dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="0dp"
        android:layout_marginBottom="0dp"
        app:cardBackgroundColor="#FAFCFF"
        app:cardCornerRadius="28dp"
        app:cardElevation="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/photoPreviewCard">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Drag handle -->
            <View
                android:layout_width="36dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="2dp"
                android:background="@drawable/bg_handle" />

            <!-- TAB BAR -->
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/editTabLayout"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_tab_container"
                app:tabBackground="@drawable/tab_selector"
                app:tabGravity="fill"
                app:tabIndicatorHeight="0dp"
                app:tabMode="fixed"
                app:tabSelectedTextColor="#FFFFFF"
                app:tabTextColor="#8899A6"
                app:tabRippleColor="@android:color/transparent"
                app:tabPaddingStart="8dp"
                app:tabPaddingEnd="8dp" />

            <!-- CONTENT PANELS — swap visibility via TabLayout listener -->

            <!-- ── PRESETS PANEL ── -->
            <LinearLayout
                android:id="@+id/panelPresets"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvPresets"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:clipToPadding="false"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:spanCount="4" />

            </LinearLayout>

            <!-- ── FILTERS PANEL ── -->
            <LinearLayout
                android:id="@+id/panelFilters"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingTop="8dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Choose Filter"
                        android:textColor="#1F618D"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUndo"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:insetBottom="0dp"
                        android:insetTop="0dp"
                        android:text=""
                        app:icon="@drawable/ic_undo_24"
                        app:iconGravity="textStart"
                        app:iconSize="22dp"
                        app:iconTint="#2A5298" />
                </LinearLayout>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvFilters"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:clipToPadding="false"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:spanCount="4" />

                <!-- Intensity slider -->
                <LinearLayout
                    android:id="@+id/filterIntensityRow"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingStart="20dp"
                    android:paddingTop="6dp"
                    android:paddingEnd="20dp"
                    android:paddingBottom="2dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:minWidth="56dp"
                        android:text="Intensity"
                        android:textColor="#1F618D"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                    <SeekBar
                        android:id="@+id/seekFilterIntensity"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10dp"
                        android:layout_marginEnd="10dp"
                        android:layout_weight="1"
                        android:max="100"
                        android:progress="80"
                        android:progressTint="#2A5298"
                        android:thumbTint="#2A5298" />

                    <TextView
                        android:id="@+id/tvIntensityValue"
                        android:layout_width="28dp"
                        android:layout_height="wrap_content"
                        android:gravity="end"
                        android:text="80"
                        android:textColor="#2A5298"
                        android:textSize="11sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </LinearLayout>

            <!-- ── FRAMES PANEL ── -->
            <LinearLayout
                android:id="@+id/panelFrames"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvFrames"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:clipToPadding="false"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:spanCount="4" />

            </LinearLayout>

            <!-- ── STICKERS PANEL ── -->
            <LinearLayout
                android:id="@+id/panelStickers"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="gone">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvStickers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:clipToPadding="false"
                    android:paddingTop="4dp"
                    android:paddingBottom="4dp"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:spanCount="4" />

            </LinearLayout>

            <!-- Spacer -->
            <View
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- ── SUMMARY + SAVE ROW ── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="20dp">

                <TextView
                    android:id="@+id/tvEditSummary"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@drawable/bg_summary_pill"
                    android:ellipsize="end"
                    android:maxLines="1"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="7dp"
                    android:text="@string/edit_summary_default"
                    android:textColor="#1F618D"
                    android:textSize="11sp" />

                <Space
                    android:layout_width="10dp"
                    android:layout_height="0dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFinishEdit"
                    android:layout_width="wrap_content"
                    android:layout_height="48dp"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:text="@string/btn_save_return"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:backgroundTint="#ff99be"
                    app:cornerRadius="24dp"
                    app:elevation="4dp"
                    app:icon="@drawable/ic_check_24"
                    app:iconGravity="textStart"
                    app:iconPadding="6dp"
                    app:iconSize="16dp"
                    app:iconTint="#FFFFFF" />

            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>