<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg"
    tools:ignore="ContentDescription">

    <!-- ── TOP APP BAR ── -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        android:paddingTop="12dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:contentInsetStart="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBack"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:insetBottom="0dp"
                android:insetTop="0dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:text=""
                app:icon="@drawable/ic_arrow_back_24"
                app:iconGravity="textStart"
                app:iconSize="24dp"
                app:iconTint="@color/screen_icon_tint" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:fontFamily="@font/pacifico_regular"
                android:text="@string/title_edit"
                android:textColor="@color/screen_title"
                android:textSize="22sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCompare"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:insetBottom="0dp"
                android:insetTop="0dp"
                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:text=""
                app:icon="@drawable/ic_visibility_24"
                app:iconGravity="textStart"
                app:iconSize="24dp"
                app:iconTint="@color/screen_icon_tint" />

        </LinearLayout>
    </com.google.android.material.appbar.MaterialToolbar>

    <!-- ── PHOTO PREVIEW CARD ── -->
    <androidx.cardview.widget.CardView
        android:id="@+id/photoPreviewCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="24dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="10dp"
        app:layout_constraintBottom_toTopOf="@id/editPanelCard"
        app:layout_constraintDimensionRatio="3:4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar"
        app:layout_constraintVertical_bias="0.0"
        app:layout_constraintHeight_max="360dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <ImageView
                android:id="@+id/ivEditingPhoto"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_dashed_border"
                android:contentDescription="@string/edit_photo_preview_content_desc"
                android:scaleType="centerCrop" />

            <ImageView
                android:id="@+id/ivFrameOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="fitXY"
                android:contentDescription="@null"
                android:importantForAccessibility="no"
                tools:ignore="ContentDescription"
                android:visibility="gone" />

            <!-- Active edit chip, floats top-right -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chipActiveEdit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:layout_margin="10dp"
                android:text="@string/edit_chip_original"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                app:chipBackgroundColor="#88000000"
                app:chipMinHeight="24dp"
                app:chipStrokeWidth="0dp" />

        </FrameLayout>
    </androidx.cardview.widget.CardView>

    <!-- ── BOTTOM EDIT PANEL ── -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/editPanelCard"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="0dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="0dp"
        android:layout_marginBottom="0dp"
        app:cardBackgroundColor="@color/screen_surface"
        app:cardCornerRadius="32dp"
        app:cardElevation="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/photoPreviewCard">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Drag handle -->
            <View
                android:layout_width="40dp"
                android:layout_height="4dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp"
                android:background="@drawable/bg_handle" />

            <!-- TAB BAR -->
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/editTabLayout"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_tab_container"
                app:tabBackground="@drawable/tab_selector"
                app:tabGravity="fill"
                app:tabIndicatorHeight="0dp"
                app:tabMode="fixed"
                app:tabSelectedTextColor="@color/white"
                app:tabTextColor="@color/screen_text_muted"
                app:tabRippleColor="@android:color/transparent"
                app:tabMaxWidth="0dp" />

            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:fillViewport="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- CONTENT PANELS -->

                    <!-- ── FILTERS PANEL ── -->
                    <LinearLayout
                        android:id="@+id/panelFilters"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="visible">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="20dp"
                            android:paddingTop="12dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/edit_select_filter"
                                android:textColor="@color/screen_subtitle"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnQuickApplyFilter"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/edit_apply"
                                android:textSize="12sp"
                                android:textColor="@color/camera_mode_primary"
                                app:icon="@drawable/ic_check_24"
                                app:iconSize="14dp" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingHorizontal="20dp"
                            android:paddingTop="4dp">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:text="@string/edit_fine_tune_selection"
                                android:textColor="@color/screen_text_muted"
                                android:textSize="12sp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnUndo"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="44dp"
                                android:layout_height="44dp"
                                android:insetBottom="0dp"
                                android:insetTop="0dp"
                                android:text=""
                                app:icon="@drawable/ic_undo_24"
                                app:iconGravity="textStart"
                                app:iconSize="22dp"
                                app:iconTint="@color/camera_mode_primary" />
                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvFilters"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:clipToPadding="false"
                            android:paddingHorizontal="12dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                            app:spanCount="4" />

                        <!-- Intensity slider -->
                        <LinearLayout
                            android:id="@+id/filterIntensityRow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="24dp"
                            android:paddingTop="8dp"
                            android:paddingEnd="24dp"
                            android:paddingBottom="4dp"
                            android:visibility="gone">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:minWidth="56dp"
                                android:text="@string/edit_intensity"
                                android:textColor="@color/screen_subtitle"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                            <SeekBar
                                android:id="@+id/seekFilterIntensity"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:layout_marginEnd="12dp"
                                android:layout_weight="1"
                                android:max="100"
                                android:progress="80"
                                android:progressTint="@color/camera_mode_primary"
                                android:thumbTint="@color/camera_mode_primary" />

                            <TextView
                                android:id="@+id/tvIntensityValue"
                                android:layout_width="28dp"
                                android:layout_height="wrap_content"
                                android:gravity="end"
                                android:text="@string/edit_default_intensity_value"
                                android:textColor="@color/camera_mode_primary"
                                android:textSize="11sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- ── FRAMES PANEL ── -->
                    <LinearLayout
                        android:id="@+id/panelFrames"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvFrames"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:clipToPadding="false"
                            android:paddingHorizontal="12dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                            app:spanCount="4" />

                    </LinearLayout>

                    <!-- ── STICKERS PANEL ── -->
                    <LinearLayout
                        android:id="@+id/panelStickers"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <com.google.android.material.tabs.TabLayout
                            android:id="@+id/stickerCategoryTabLayout"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:layout_marginStart="16dp"
                            android:layout_marginTop="8dp"
                            android:layout_marginEnd="16dp"
                            android:background="@drawable/bg_tab_container"
                            app:tabBackground="@drawable/tab_selector"
                            app:tabGravity="fill"
                            app:tabIndicatorHeight="0dp"
                            app:tabMode="fixed"
                            app:tabRippleColor="@android:color/transparent"
                            app:tabSelectedTextColor="@color/white"
                            app:tabTextColor="@color/screen_text_muted" />

                        <LinearLayout
                            android:id="@+id/stickerSizeRow"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal"
                            android:paddingStart="20dp"
                            android:paddingTop="10dp"
                            android:paddingEnd="20dp"
                            android:visibility="gone">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/edit_sticker_size"
                                android:textColor="@color/screen_subtitle"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                            <SeekBar
                                android:id="@+id/seekStickerSize"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:layout_marginEnd="12dp"
                                android:layout_weight="1"
                                android:max="270"
                                android:progress="70"
                                android:progressTint="@color/camera_mode_primary"
                                android:thumbTint="@color/camera_mode_primary" />

                            <TextView
                                android:id="@+id/tvStickerSizeValue"
                                android:layout_width="44dp"
                                android:layout_height="wrap_content"
                                android:gravity="end"
                                android:text="100%"
                                android:textColor="@color/camera_mode_primary"
                                android:textSize="12sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="20dp"
                            android:layout_marginEnd="20dp"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="4dp"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <com.google.android.material.chip.ChipGroup
                                android:id="@+id/stickerSizePresetGroup"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                app:chipSpacingHorizontal="8dp"
                                app:singleSelection="true"
                                android:visibility="gone">

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/chipStickerSizeSmall"
                                    style="@style/Widget.MaterialComponents.Chip.Choice"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:checkable="true"
                                    app:chipBackgroundColor="@color/selector_sticker_size_chip_bg"
                                    app:chipStrokeColor="@color/camera_mode_primary"
                                    app:chipStrokeWidth="1dp"
                                    android:textColor="@color/selector_sticker_size_chip_text"
                                    android:text="@string/edit_sticker_size_small" />

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/chipStickerSizeMedium"
                                    style="@style/Widget.MaterialComponents.Chip.Choice"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:checkable="true"
                                    app:chipBackgroundColor="@color/selector_sticker_size_chip_bg"
                                    app:chipStrokeColor="@color/camera_mode_primary"
                                    app:chipStrokeWidth="1dp"
                                    android:textColor="@color/selector_sticker_size_chip_text"
                                    android:text="@string/edit_sticker_size_medium" />

                                <com.google.android.material.chip.Chip
                                    android:id="@+id/chipStickerSizeLarge"
                                    style="@style/Widget.MaterialComponents.Chip.Choice"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:checkable="true"
                                    app:chipBackgroundColor="@color/selector_sticker_size_chip_bg"
                                    app:chipStrokeColor="@color/camera_mode_primary"
                                    app:chipStrokeWidth="1dp"
                                    android:textColor="@color/selector_sticker_size_chip_text"
                                    android:text="@string/edit_sticker_size_large" />

                            </com.google.android.material.chip.ChipGroup>

                            <LinearLayout
                                android:id="@+id/stickerQuickActionsRow"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:gravity="end|center_vertical"
                                android:orientation="horizontal"
                                android:visibility="gone">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnStickerCenter"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:minWidth="0dp"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:text="@string/edit_sticker_center"
                                android:textAllCaps="false"
                                android:textColor="@color/camera_mode_primary"
                                android:textSize="11sp" />

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnStickerReset"
                                style="@style/Widget.MaterialComponents.Button.TextButton"
                                android:layout_width="wrap_content"
                                android:layout_height="36dp"
                                android:minWidth="0dp"
                                android:paddingStart="10dp"
                                android:paddingEnd="10dp"
                                android:text="@string/edit_sticker_reset"
                                android:textAllCaps="false"
                                android:textColor="@color/camera_mode_primary"
                                android:textSize="11sp" />

                            </LinearLayout>

                        </LinearLayout>

                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rvStickers"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:clipToPadding="false"
                            android:paddingHorizontal="12dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp"
                            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                            app:spanCount="4" />

                    </LinearLayout>

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/screen_divider" />

            <!-- ── SAVE BUTTON ROW ── -->
            <FrameLayout
                android:id="@+id/persistentBottomBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/screen_surface_alt"
                android:paddingHorizontal="24dp"
                android:paddingTop="12dp"
                android:paddingBottom="32dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnFinishEdit"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:text="@string/btn_save_return"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/history_pill_pink"
                    app:cornerRadius="27dp"
                    app:elevation="4dp"
                    app:icon="@drawable/ic_check_24"
                    app:iconGravity="textStart"
                    app:iconPadding="8dp"
                    app:iconSize="20dp"
                    app:iconTint="@color/white" />

            </FrameLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>

