<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_bg_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- AI Chat Search Bar -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAiChatSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/surface_card"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_sparkle"
                    app:tint="@color/app_blue" />

                <TextView
                    android:id="@+id/tvAiChatPrompt"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="12dp"
                    android:text="@string/admin_ai_chat_search_hint"
                    android:textColor="@color/admin_subtitle_color"
                    android:textSize="14sp" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_send_outline"
                    app:tint="@color/admin_subtitle_color" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Chart Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardOverviewSummary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:visibility="gone"
            app:cardCornerRadius="@dimen/admin_card_corner_radius"
            app:cardElevation="@dimen/admin_card_elevation"
            app:cardBackgroundColor="@color/surface_card"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvBigAvg"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0"
                            android:textColor="@color/app_blue"
                            android:textSize="36sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvChartSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/admin_overview_chart_subtitle_placeholder"
                            android:textColor="@color/admin_subtitle_color"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvLastReviewAt"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/admin_overview_last_review_fallback"
                            android:textColor="@color/admin_subtitle_color"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:id="@+id/tvBigTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/app_blue"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvTotalReviewsLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/admin_overview_total_reviews"
                            android:textColor="@color/admin_subtitle_color"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvBig5Star"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0"
                            android:textColor="#27A869"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvFiveStarLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/admin_overview_five_star_label"
                            android:textColor="@color/admin_subtitle_color"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Chart Bars -->
                <!-- 5 Stars -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp"
                    android:orientation="horizontal">
                    <TextView android:id="@+id/tvBar5Label" android:layout_width="32dp" android:layout_height="wrap_content" android:text="@string/admin_overview_bar_five" android:textSize="11sp" android:textColor="@color/text_secondary"/>
                    <FrameLayout android:layout_width="0dp" android:layout_height="8dp" android:layout_weight="1" android:layout_marginHorizontal="8dp" android:background="@drawable/shape_bar_track">
                        <View android:id="@+id/bar5Star" android:layout_width="0dp" android:layout_height="match_parent" android:background="@drawable/shape_bar_fill_green"/>
                    </FrameLayout>
                    <TextView android:id="@+id/tv5StarCount" android:layout_width="24dp" android:layout_height="wrap_content" android:text="0" android:textSize="11sp" android:textColor="@color/text_secondary" android:gravity="end"/>
                </LinearLayout>

                <!-- 4 Stars -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp"
                    android:orientation="horizontal">
                    <TextView android:id="@+id/tvBar4Label" android:layout_width="32dp" android:layout_height="wrap_content" android:text="@string/admin_overview_bar_four" android:textSize="11sp" android:textColor="@color/text_secondary"/>
                    <FrameLayout android:layout_width="0dp" android:layout_height="8dp" android:layout_weight="1" android:layout_marginHorizontal="8dp" android:background="@drawable/shape_bar_track">
                        <View android:id="@+id/bar4Star" android:layout_width="0dp" android:layout_height="match_parent" android:background="@drawable/shape_bar_fill_blue"/>
                    </FrameLayout>
                    <TextView android:id="@+id/tv4StarCount" android:layout_width="24dp" android:layout_height="wrap_content" android:text="0" android:textSize="11sp" android:textColor="@color/text_secondary" android:gravity="end"/>
                </LinearLayout>

                <!-- 3 Stars -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp"
                    android:orientation="horizontal">
                    <TextView android:id="@+id/tvBar3Label" android:layout_width="32dp" android:layout_height="wrap_content" android:text="@string/admin_overview_bar_three" android:textSize="11sp" android:textColor="@color/text_secondary"/>
                    <FrameLayout android:layout_width="0dp" android:layout_height="8dp" android:layout_weight="1" android:layout_marginHorizontal="8dp" android:background="@drawable/shape_bar_track">
                        <View android:id="@+id/bar3Star" android:layout_width="0dp" android:layout_height="match_parent" android:background="@drawable/shape_bar_fill_gold"/>
                    </FrameLayout>
                    <TextView android:id="@+id/tv3StarCount" android:layout_width="24dp" android:layout_height="wrap_content" android:text="0" android:textSize="11sp" android:textColor="@color/text_secondary" android:gravity="end"/>
                </LinearLayout>

                <!-- 2 Stars -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp"
                    android:orientation="horizontal">
                    <TextView android:id="@+id/tvBar2Label" android:layout_width="32dp" android:layout_height="wrap_content" android:text="@string/admin_overview_bar_two" android:textSize="11sp" android:textColor="@color/text_secondary"/>
                    <FrameLayout android:layout_width="0dp" android:layout_height="8dp" android:layout_weight="1" android:layout_marginHorizontal="8dp" android:background="@drawable/shape_bar_track">
                        <View android:id="@+id/bar2Star" android:layout_width="0dp" android:layout_height="match_parent" android:background="@drawable/shape_bar_fill_orange"/>
                    </FrameLayout>
                    <TextView android:id="@+id/tv2StarCount" android:layout_width="24dp" android:layout_height="wrap_content" android:text="0" android:textSize="11sp" android:textColor="@color/text_secondary" android:gravity="end"/>
                </LinearLayout>

                <!-- 1 Star -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView android:id="@+id/tvBar1Label" android:layout_width="32dp" android:layout_height="wrap_content" android:text="@string/admin_overview_bar_one" android:textSize="11sp" android:textColor="@color/text_secondary"/>
                    <FrameLayout android:layout_width="0dp" android:layout_height="8dp" android:layout_weight="1" android:layout_marginHorizontal="8dp" android:background="@drawable/shape_bar_track">
                        <View android:id="@+id/bar1Star" android:layout_width="0dp" android:layout_height="match_parent" android:background="@drawable/shape_bar_fill_red"/>
                    </FrameLayout>
                    <TextView android:id="@+id/tv1StarCount" android:layout_width="24dp" android:layout_height="wrap_content" android:text="0" android:textSize="11sp" android:textColor="@color/text_secondary" android:gravity="end"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvRangeTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/admin_overview_range_title"
                android:textColor="@color/admin_subtitle_color"
                android:textSize="12sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:singleLine="true" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleRange"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:checkedButton="@id/btnRange6m"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRange3m"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:text="@string/admin_overview_range_3m"
                    android:textAllCaps="false"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRange6m"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:text="@string/admin_overview_range_6m"
                    android:textAllCaps="false"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRange12m"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:text="@string/admin_overview_range_12m"
                    android:textAllCaps="false"
                    android:textSize="12sp" />

            </com.google.android.material.button.MaterialButtonToggleGroup>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAiInsights"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="@dimen/admin_card_corner_radius_item"
            app:cardElevation="@dimen/admin_card_elevation"
            app:cardBackgroundColor="@color/surface_card"
            app:strokeColor="@color/admin_card_stroke"
            app:strokeWidth="1dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvAiInsightsTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/admin_ai_insights_title"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnAiAnalyze"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="34dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:text="@string/admin_ai_insights_analyze_cta"
                        android:textAllCaps="false"
                        android:textSize="11sp" />

                    <ProgressBar
                        android:id="@+id/progressAiInsights"
                        style="?android:attr/progressBarStyleSmall"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_marginStart="8dp"
                        android:visibility="gone" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvAiInsightsSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/admin_ai_insights_tap_to_analyze"
                    android:textColor="@color/admin_subtitle_color"
                    android:textSize="11sp" />

                <!-- Empty State Container -->
                <LinearLayout
                    android:id="@+id/layoutAiEmptyState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingTop="16dp"
                    android:paddingBottom="10dp">
                    
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_sparkle"
                        android:alpha="0.2"
                        app:tint="@color/text_secondary" />
                        
                    <TextView
                        android:id="@+id/tvAiEmptyTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:text="@string/admin_ai_insights_empty_title"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                        
                    <TextView
                        android:id="@+id/tvAiEmptyDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center"
                        android:text="@string/admin_ai_insights_empty_desc"
                        android:textColor="@color/admin_subtitle_color"
                        android:textSize="12sp" />
                </LinearLayout>

                <!-- Result State Container (Initially Hidden) -->
                <LinearLayout
                    android:id="@+id/layoutAiResultState"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/tvAiSummary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textColor="@color/text_primary"
                        android:textSize="14sp"
                        android:lineSpacingExtra="4dp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp">
                        <ImageView
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:src="@drawable/shape_circle_dot"
                            app:tint="@color/text_secondary"
                            android:layout_marginTop="6dp"
                            android:layout_marginEnd="8dp"/>
                        <TextView
                            android:id="@+id/tvAiInsightLine1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:lineSpacingExtra="6dp"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp">
                        <ImageView
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:src="@drawable/shape_circle_dot"
                            app:tint="@color/text_secondary"
                            android:layout_marginTop="6dp"
                            android:layout_marginEnd="8dp"/>
                        <TextView
                            android:id="@+id/tvAiInsightLine2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:lineSpacingExtra="6dp"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="10dp">
                        <ImageView
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:src="@drawable/shape_circle_dot"
                            app:tint="@color/text_secondary"
                            android:layout_marginTop="6dp"
                            android:layout_marginEnd="8dp"/>
                        <TextView
                            android:id="@+id/tvAiInsightLine3"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:lineSpacingExtra="6dp"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/bg_ai_recommendation"
                        android:padding="12dp">
                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_sparkle"
                            app:tint="@color/app_blue"
                            android:layout_marginEnd="8dp"/>
                        <TextView
                            android:id="@+id/tvAiRecommendation"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/app_blue"
                            android:textSize="13sp"
                            android:lineSpacingExtra="4dp"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardAiRatioMini"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:clickable="true"
            android:focusable="true"
            app:cardCornerRadius="@dimen/admin_card_corner_radius_item"
            app:cardElevation="@dimen/admin_card_elevation"
            app:cardBackgroundColor="@color/surface_card"
            app:strokeColor="@color/admin_card_stroke"
            app:rippleColor="#1A1A2A6C"
            app:strokeWidth="1dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="@dimen/admin_ai_mini_card_padding">

                <com.example.expressionphotobooth.ui.chart.AiRatioPieChartView
                    android:id="@+id/pieAiRatioMini"
                    android:layout_width="@dimen/admin_ai_mini_pie_size"
                    android:layout_height="@dimen/admin_ai_mini_pie_size"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tvAiRatioMiniPercent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/admin_ai_mini_percent_text"
                    android:textStyle="bold"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/admin_ai_mini_gap"
                    android:layout_marginEnd="@dimen/admin_ai_mini_gap"
                    android:orientation="vertical"
                    app:layout_constraintBottom_toBottomOf="@id/pieAiRatioMini"
                    app:layout_constraintEnd_toStartOf="@id/tvAiRatioMiniPercent"
                    app:layout_constraintStart_toEndOf="@id/pieAiRatioMini"
                    app:layout_constraintTop_toTopOf="@id/pieAiRatioMini">

                    <TextView
                        android:id="@+id/tvAiRatioMiniTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/admin_ai_pie_title"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/admin_ai_mini_title_text"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvAiRatioMiniMeta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:text="@string/admin_ai_registered_with_count"
                        android:textColor="@color/admin_subtitle_color"
                        android:textSize="@dimen/admin_ai_mini_meta_text" />
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardUsersChart"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="@dimen/admin_card_corner_radius"
            app:cardElevation="@dimen/admin_card_elevation"
            app:cardBackgroundColor="@color/surface_card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">
                    <TextView
                        android:id="@+id/tvUsersChartTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/admin_overview_users_chart_title"
                        android:textColor="@color/admin_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnDetailUsersChart"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:insetLeft="0dp"
                        android:insetTop="0dp"
                        android:insetRight="0dp"
                        android:insetBottom="0dp"
                        app:icon="@drawable/ic_info_24"
                        app:iconSize="18dp"
                        app:iconTint="@color/app_blue"
                        app:iconPadding="0dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvUsersChartSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/admin_overview_users_chart_subtitle"
                    android:textColor="@color/admin_subtitle_color"
                    android:textSize="11sp" />

                <com.example.expressionphotobooth.ui.chart.MonthlyBarChartView
                    android:id="@+id/chartUsersByMonth"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:layout_marginTop="12dp"
                    android:paddingBottom="4dp" />

                <TextView
