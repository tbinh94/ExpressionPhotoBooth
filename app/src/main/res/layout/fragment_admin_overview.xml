<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_bg_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Chart Card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFFFFF"
            app:strokeWidth="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="24dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvBigAvg"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0"
                            android:textColor="@color/app_blue"
                            android:textSize="36sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvChartSubtitle"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/admin_overview_chart_subtitle_placeholder"
                            android:textColor="#8A9BB8"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tvLastReviewAt"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="@string/admin_overview_last_review_fallback"
                            android:textColor="#8A9BB8"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="1" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="end">

                        <TextView
                            android:id="@+id/tvBigTotal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textColor="@color/app_blue"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/admin_overview_total_reviews"
                            android:textColor="#8A9BB8"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvBig5Star"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="0"
                            android:textColor="#27A869"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="@string/admin_overview_five_star_label"
                            android:textColor="#8A9BB8"
                            android:textSize="11sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Chart Bars -->
                <!-- 5 Stars -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp"
                    android:orientation="horizontal">
                    <TextView android:layout_width="32dp" android:layout_height="wrap_content" android:text="@string/admin_overview_bar_five" android:textSize="11sp" android:textColor="#4A5D77"/>
                    <FrameLayout android:layout_width="0dp" android:layout_height="8dp" android:layout_weight="1" android:layout_marginHorizontal="8dp" android:background="@drawable/shape_bar_track">
                        <View android:id="@+id/bar5Star" android:layout_width="0dp" android:layout_height="match_parent" android:background="@drawable/shape_bar_fill_green"/>
                    </FrameLayout>
                    <TextView android:id="@+id/tv5StarCount" android:layout_width="24dp" android:layout_height="wrap_content" android:text="0" android:textSize="11sp" android:textColor="#4A5D77" android:gravity="end"/>
                </LinearLayout>

                <!-- 4 Stars -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp"
                    android:orientation="horizontal">
                    <TextView android:layout_width="32dp" android:layout_height="wrap_content" android:text="@string/admin_overview_bar_four" android:textSize="11sp" android:textColor="#4A5D77"/>
                    <FrameLayout android:layout_width="0dp" android:layout_height="8dp" android:layout_weight="1" android:layout_marginHorizontal="8dp" android:background="@drawable/shape_bar_track">
                        <View android:id="@+id/bar4Star" android:layout_width="0dp" android:layout_height="match_parent" android:background="@drawable/shape_bar_fill_blue"/>
                    </FrameLayout>
                    <TextView android:id="@+id/tv4StarCount" android:layout_width="24dp" android:layout_height="wrap_content" android:text="0" android:textSize="11sp" android:textColor="#4A5D77" android:gravity="end"/>
                </LinearLayout>

                <!-- 3 Stars -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp"
                    android:orientation="horizontal">
                    <TextView android:layout_width="32dp" android:layout_height="wrap_content" android:text="@string/admin_overview_bar_three" android:textSize="11sp" android:textColor="#4A5D77"/>
                    <FrameLayout android:layout_width="0dp" android:layout_height="8dp" android:layout_weight="1" android:layout_marginHorizontal="8dp" android:background="@drawable/shape_bar_track">
                        <View android:id="@+id/bar3Star" android:layout_width="0dp" android:layout_height="match_parent" android:background="@drawable/shape_bar_fill_gold"/>
                    </FrameLayout>
                    <TextView android:id="@+id/tv3StarCount" android:layout_width="24dp" android:layout_height="wrap_content" android:text="0" android:textSize="11sp" android:textColor="#4A5D77" android:gravity="end"/>
                </LinearLayout>

                <!-- 2 Stars -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp"
                    android:orientation="horizontal">
                    <TextView android:layout_width="32dp" android:layout_height="wrap_content" android:text="@string/admin_overview_bar_two" android:textSize="11sp" android:textColor="#4A5D77"/>
                    <FrameLayout android:layout_width="0dp" android:layout_height="8dp" android:layout_weight="1" android:layout_marginHorizontal="8dp" android:background="@drawable/shape_bar_track">
                        <View android:id="@+id/bar2Star" android:layout_width="0dp" android:layout_height="match_parent" android:background="@drawable/shape_bar_fill_orange"/>
                    </FrameLayout>
                    <TextView android:id="@+id/tv2StarCount" android:layout_width="24dp" android:layout_height="wrap_content" android:text="0" android:textSize="11sp" android:textColor="#4A5D77" android:gravity="end"/>
                </LinearLayout>

                <!-- 1 Star -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">
                    <TextView android:layout_width="32dp" android:layout_height="wrap_content" android:text="@string/admin_overview_bar_one" android:textSize="11sp" android:textColor="#4A5D77"/>
                    <FrameLayout android:layout_width="0dp" android:layout_height="8dp" android:layout_weight="1" android:layout_marginHorizontal="8dp" android:background="@drawable/shape_bar_track">
                        <View android:id="@+id/bar1Star" android:layout_width="0dp" android:layout_height="match_parent" android:background="@drawable/shape_bar_fill_red"/>
                    </FrameLayout>
                    <TextView android:id="@+id/tv1StarCount" android:layout_width="24dp" android:layout_height="wrap_content" android:text="0" android:textSize="11sp" android:textColor="#4A5D77" android:gravity="end"/>
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/admin_overview_range_title"
                android:textColor="#5D6F89"
                android:textSize="12sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggleRange"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:checkedButton="@id/btnRange6m"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRange3m"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:text="@string/admin_overview_range_3m"
                    android:textAllCaps="false"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRange6m"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:text="@string/admin_overview_range_6m"
                    android:textAllCaps="false"
                    android:textSize="12sp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRange12m"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:text="@string/admin_overview_range_12m"
                    android:textAllCaps="false"
                    android:textSize="12sp" />

            </com.google.android.material.button.MaterialButtonToggleGroup>
        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_overview_users_chart_title"
                    android:textColor="@color/app_blue"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/admin_overview_users_chart_subtitle"
                    android:textColor="#8A9BB8"
                    android:textSize="11sp" />

                <com.example.expressionphotobooth.ui.chart.MonthlyBarChartView
                    android:id="@+id/chartUsersByMonth"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:layout_marginTop="12dp"
                    android:paddingBottom="4dp" />

                <TextView
                    android:id="@+id/tvUsersByMonthEmpty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/admin_overview_trend_empty"
                    android:textColor="#8A9BB8"
                    android:textSize="11sp"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_overview_download_chart_title"
                    android:textColor="@color/app_blue"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/admin_overview_download_chart_subtitle"
                    android:textColor="#8A9BB8"
                    android:textSize="11sp" />

                <com.example.expressionphotobooth.ui.chart.MonthlyBarChartView
                    android:id="@+id/chartImageDownloadsByMonth"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:layout_marginTop="12dp"
                    android:paddingBottom="4dp" />

                <TextView
                    android:id="@+id/tvImageDownloadsByMonthEmpty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/admin_overview_trend_empty"
                    android:textColor="#8A9BB8"
                    android:textSize="11sp"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="1dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/admin_overview_review_score_chart_title"
                    android:textColor="@color/app_blue"
                    android:textStyle="bold"
                    android:textSize="14sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="@string/admin_overview_review_score_chart_subtitle"
                    android:textColor="#8A9BB8"
                    android:textSize="11sp" />

                <com.example.expressionphotobooth.ui.chart.MonthlyBarChartView
                    android:id="@+id/chartReviewScoreByMonth"
                    android:layout_width="match_parent"
                    android:layout_height="180dp"
                    android:layout_marginTop="12dp"
                    android:paddingBottom="4dp" />

                <TextView
                    android:id="@+id/tvReviewScoreByMonthEmpty"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="@string/admin_overview_trend_empty"
                    android:textColor="#8A9BB8"
                    android:textSize="11sp"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
