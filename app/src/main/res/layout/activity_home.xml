<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/homeContentRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_home_modern_gradient">

        <ImageView
            android:id="@+id/ivHomeBanner"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            android:src="@drawable/photo_banner"
            tools:ignore="ContentDescription"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <View
            android:id="@+id/viewHomeBannerDimmer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/bg_home_dark_scrim"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <FrameLayout
                android:id="@+id/btnMenu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/shape_glass_circle"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">
                
                <ImageView
                    android:id="@+id/ivMenuIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_menu_24"
                    app:tint="#FFFFFF" />
            </FrameLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/titleContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/topBar"
            app:layout_constraintBottom_toTopOf="@+id/mainContent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.25">

            <TextView
                android:id="@+id/tvHomeOur"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_title_our"
                android:textColor="#FFFFFF"
                android:textSize="48sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.05"
                android:shadowColor="#80000000"
                android:shadowDx="0"
                android:shadowDy="4"
                android:shadowRadius="8" />

            <TextView
                android:id="@+id/tvHomeMemories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="-12dp"
                android:text="@string/home_title_memories"
                android:textColor="#FBBF24"
                android:textSize="56sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.05"
                android:shadowColor="#80000000"
                android:shadowDx="0"
                android:shadowDy="4"
                android:shadowRadius="8" />

            <TextView
                android:id="@+id/tvHomePhotobooth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/home_title_photobooth"
                android:textColor="#E2E8F0"
                android:textSize="36sp"
                android:fontFamily="@font/pacifico_regular"
                android:shadowColor="#FF4081"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="12" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/mainContent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.85">

            <FrameLayout
                android:id="@+id/btnStart"
                android:layout_width="240dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_home_start_button"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:elevation="8dp">
                
                <TextView
                    android:id="@+id/tvStartText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="✦ BẮT ĐẦU ✦"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />
            </FrameLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGallery"
                android:layout_width="240dp"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:text="@string/btn_gallery"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:backgroundTint="#33FFFFFF"
                app:cornerRadius="28dp"
                app:elevation="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdmin"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:text="@string/admin_go_to_dashboard"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:visibility="gone"
                app:icon="@drawable/ic_settings_24"
                app:iconTint="@color/white"
                app:backgroundTint="#1AFFFFFF"
                app:cornerRadius="24dp" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/drawerPanel"
        android:layout_width="@dimen/admin_nav_drawer_width"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/home_drawer_bg"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/home_drawer_padding_horizontal"
        android:paddingTop="@dimen/home_drawer_padding_top"
        android:paddingBottom="@dimen/home_drawer_padding_bottom">

        <!-- ✦ User Profile Header (Vertical Design) ✦ -->
        <LinearLayout
            android:id="@+id/cardNavUserProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_home_glass_card"
            android:orientation="vertical"
            android:padding="20dp"
            android:clickable="true"
            android:focusable="true">
 
            <!-- Row 1: Avatar + Name -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/shape_nav_avatar">
                    
                    <TextView
                        android:id="@+id/tvNavAvatarInitials"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:text="U"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold" />
     
                    <com.google.android.material.imageview.ShapeableImageView
                        android:id="@+id/ivNavAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:visibility="gone"
                        app:shapeAppearanceOverlay="@style/CircleAppearance" />
                </FrameLayout>

                <TextView
                    android:id="@+id/tvNavUserName"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:text="User Name"
                    android:textColor="#FFFFFF"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:ellipsize="end"
                    android:maxLines="1" />
            </LinearLayout>

            <!-- Row 2: Email -->
            <TextView
                android:id="@+id/tvNavUserEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="user@example.com"
                android:textColor="#94A3B8"
                android:textSize="13sp"
                android:ellipsize="end"
                android:maxLines="1" />

            <!-- Row 3: Role Badge -->
            <TextView
                android:id="@+id/tvNavUserRole"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_nav_role_pill"
                android:paddingHorizontal="12dp"
                android:paddingVertical="3dp"
                android:text="Member"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textAllCaps="true"
                android:letterSpacing="0.05" />
        </LinearLayout>

        <!-- === MENU === -->
        <TextView
            android:id="@+id/tvDrawerNavLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            android:gravity="center"
            android:text="@string/home_drawer_nav_label"
            android:textColor="#475569"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.2" />

        <LinearLayout
            android:id="@+id/itemGallery"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/bg_drawer_item_clickable"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:clickable="true"
            android:focusable="true">
            
            <TextView
                android:id="@+id/tvDrawerShowHistory"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawableStart="@drawable/ic_grid_view_24"
                android:drawablePadding="16dp"
                android:drawableTint="#CBD5E1"
                android:text="@string/home_drawer_show_history"
                android:textColor="#F8FAFC"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_arrow_forward_24"
                app:tint="#4DFFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/itemBanner"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/bg_drawer_item_clickable"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:clickable="true"
            android:focusable="true">
            
            <TextView
                android:id="@+id/tvDrawerChangeBanner"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawableStart="@drawable/ic_image_24"
                android:drawablePadding="16dp"
                android:drawableTint="#CBD5E1"
                android:text="@string/home_drawer_change_banner"
                android:textColor="#F8FAFC"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_arrow_forward_24"
                app:tint="#4DFFFFFF" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/itemGuide"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/bg_drawer_item_clickable"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:clickable="true"
            android:focusable="true">
            
            <TextView
                android:id="@+id/tvDrawerUsageGuide"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawableStart="@drawable/ic_help_24"
                android:drawablePadding="16dp"
                android:drawableTint="#CBD5E1"
                android:text="@string/home_drawer_usage_guide"
                android:textColor="#F8FAFC"
                android:textSize="16sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_arrow_forward_24"
                app:tint="#4DFFFFFF" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvDrawerAdminDashboard"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/bg_drawer_item_clickable"
            android:drawableStart="@drawable/ic_settings_24"
            android:drawablePadding="16dp"
            android:drawableTint="#CBD5E1"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp"
            android:text="@string/admin_go_to_dashboard"
            android:textColor="#F8FAFC"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- === SETTINGS === -->
        <TextView
            android:id="@+id/tvDrawerSettingsLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp"
            android:gravity="center"
            android:text="@string/home_drawer_settings_label"
            android:textColor="#475569"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.2" />

        <!-- Music Setting -->
        <LinearLayout
            android:id="@+id/itemMusic"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/bg_drawer_item_clickable"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <TextView
                android:id="@+id/tvDrawerMusicLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawableStart="@drawable/ic_volume_up"
                android:drawablePadding="16dp"
                android:drawableTint="#CBD5E1"
                android:text="@string/home_drawer_music"
                android:textColor="#F8FAFC"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.google.android.material.materialswitch.MaterialSwitch
                android:id="@+id/switchMusic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:thumbTint="@color/white"
                app:trackTint="#4DFFFFFF" />
        </LinearLayout>

        <!-- Theme Setting -->
        <LinearLayout
            android:id="@+id/itemTheme"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/bg_drawer_item_clickable"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <TextView
                android:id="@+id/tvDrawerThemeLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawableStart="@drawable/ic_auto_awesome"
                android:drawablePadding="16dp"
                android:drawableTint="#CBD5E1"
                android:text="@string/home_drawer_theme"
                android:textColor="#F8FAFC"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/groupTheme"
                android:layout_width="110dp"
                android:layout_height="32dp"
                android:background="@drawable/bg_drawer_spinner"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnThemeLight"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    app:icon="@drawable/ic_theme_sun_20"
                    app:iconGravity="textTop"
                    app:iconSize="18dp"
                    app:iconTint="@color/home_toggle_text"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnThemeDark"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    app:icon="@drawable/ic_theme_moon_20"
                    app:iconGravity="textTop"
                    app:iconSize="18dp"
                    app:iconTint="@color/home_toggle_text"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnThemeSystem"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:padding="0dp"
                    app:icon="@drawable/ic_sparkle"
                    app:iconGravity="textTop"
                    app:iconSize="18dp"
                    app:iconTint="@color/home_toggle_text"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="12dp" />
            </com.google.android.material.button.MaterialButtonToggleGroup>
        </LinearLayout>

        <!-- Language Setting -->
        <LinearLayout
            android:id="@+id/itemLanguage"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="4dp"
            android:background="@drawable/bg_drawer_item_clickable"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:id="@+id/tvDrawerLanguageLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:drawableStart="@drawable/ic_language_24"
                android:drawablePadding="16dp"
                android:drawableTint="#CBD5E1"
                android:text="@string/home_drawer_language"
                android:textColor="#F8FAFC"
                android:textSize="16sp"
                android:textStyle="bold" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivLanguageFlag"
                android:layout_width="24dp"
                android:layout_height="16dp"
                android:layout_marginEnd="12dp"
                android:src="@drawable/ic_flag_vn"
                android:scaleType="centerCrop"
                app:shapeAppearanceOverlay="@style/RoundedAppearance" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_arrow_forward_24"
                app:tint="#4DFFFFFF" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />
  
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDrawerSignOut"
            style="@style/Widget.Material3.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginBottom="16dp"
            android:text="@string/auth_sign_out"
            android:textAllCaps="false"
            android:textColor="#EF4444"
            android:textSize="15sp"
            android:textStyle="bold"
            app:icon="@drawable/ic_logout_24"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="#EF4444"
            android:background="@drawable/bg_drawer_item_clickable" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
