<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/homeContentRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <ImageView
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            android:src="@drawable/photo_banner"
            tools:ignore="ContentDescription"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/home_top_bar_margin_top"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="@dimen/home_top_bar_padding_horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnMenu"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="@dimen/home_top_action_size"
                android:layout_height="@dimen/home_top_action_size"
                android:insetLeft="0dp"
                android:insetTop="0dp"
                android:insetRight="0dp"
                android:insetBottom="0dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:padding="0dp"
                android:gravity="center"
                app:backgroundTint="@color/home_top_action_bg"
                app:cornerRadius="@dimen/home_top_action_corner_radius"
                app:icon="@drawable/ic_menu_24"
                app:iconGravity="textTop"
                app:iconPadding="0dp"
                app:iconSize="@dimen/home_top_action_icon_size"
                app:iconTint="@color/white" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/mainContent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:maxWidth="@dimen/home_content_max_width"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.86">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStart"
                android:layout_width="@dimen/home_main_button_width"
                android:layout_height="@dimen/home_main_button_height"
                android:text="@string/btn_start_decorated"
                android:textColor="@color/white"
                android:textSize="@dimen/home_main_start_text_size"
                android:textStyle="bold"
                app:backgroundTint="@color/history_pill_pink"
                app:cornerRadius="@dimen/home_main_button_corner_radius"
                app:elevation="@dimen/home_main_start_elevation" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGallery"
                android:layout_width="@dimen/home_main_button_width"
                android:layout_height="@dimen/home_main_button_height"
                android:layout_marginTop="@dimen/home_main_button_spacing"
                android:text="@string/btn_gallery"
                android:textColor="@color/white"
                android:textSize="@dimen/home_main_gallery_text_size"
                android:textStyle="bold"
                android:visibility="gone"
                app:backgroundTint="@color/home_gallery_button_bg"
                app:cornerRadius="@dimen/home_main_button_corner_radius"
                app:elevation="@dimen/home_main_gallery_elevation" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdmin"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="@dimen/home_admin_height"
                android:layout_marginTop="@dimen/home_admin_top_margin"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="@string/admin_go_to_dashboard"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="@dimen/home_admin_text_size"
                android:textStyle="bold"
                android:visibility="gone"
                app:icon="@drawable/ic_settings_24"
                app:iconTint="@color/white"
                app:backgroundTint="@color/home_admin_chip_bg"
                app:cornerRadius="@dimen/home_admin_corner_radius" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/drawerPanel"
        android:layout_width="@dimen/admin_nav_drawer_width"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/home_drawer_bg"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/home_drawer_padding_horizontal"
        android:paddingTop="@dimen/home_drawer_padding_top"
        android:paddingBottom="@dimen/home_drawer_padding_bottom">

        <TextView
            android:id="@+id/tvDrawerOur"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:fontFamily="serif"
            android:gravity="center"
            android:text="@string/home_drawer_our"
            android:textAllCaps="true"
            android:textColor="@color/home_drawer_text"
            android:textSize="@dimen/home_drawer_title_text_size"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDrawerMemories"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/home_drawer_subtitle_top_margin"
            android:includeFontPadding="false"
            android:fontFamily="serif"
            android:gravity="center"
            android:text="@string/home_drawer_memories"
            android:textAllCaps="true"
            android:textColor="@color/home_drawer_text"
            android:textSize="@dimen/home_drawer_title_text_size"
            android:textStyle="bold" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="@dimen/home_drawer_divider_top_margin"
            android:background="@color/home_drawer_divider" />

        <TextView
            android:id="@+id/tvDrawerShowHistory"
            android:layout_width="match_parent"
            android:layout_height="@dimen/home_drawer_item_height"
            android:layout_marginTop="@dimen/home_drawer_item_top_margin"
            android:background="@drawable/bg_drawer_item_clickable"
            android:drawableStart="@drawable/ic_grid_view_24"
            android:drawablePadding="@dimen/home_drawer_item_padding_horizontal"
            android:drawableTint="@color/home_drawer_text"
            android:fontFamily="serif"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/home_drawer_item_padding_horizontal"
            android:text="@string/home_drawer_show_history"
            android:textColor="@color/home_drawer_text"
            android:textSize="@dimen/home_drawer_item_text_size"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDrawerAdminDashboard"
            android:layout_width="match_parent"
            android:layout_height="@dimen/home_drawer_item_height"
            android:layout_marginTop="@dimen/home_drawer_item_secondary_top_margin"
            android:background="@drawable/bg_drawer_item_clickable"
            android:drawableStart="@drawable/ic_settings_24"
            android:drawablePadding="@dimen/home_drawer_item_padding_horizontal"
            android:drawableTint="@color/home_drawer_text"
            android:fontFamily="serif"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/home_drawer_item_padding_horizontal"
            android:text="@string/admin_go_to_dashboard"
            android:textColor="@color/home_drawer_text"
            android:textSize="@dimen/home_drawer_item_text_size"
            android:textStyle="bold"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/home_drawer_section_top_margin"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvDrawerMusicLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="serif"
                android:text="@string/home_drawer_music"
                android:textColor="@color/home_drawer_text"
                android:textSize="@dimen/home_drawer_label_text_size"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/groupMusicState"
                android:layout_width="@dimen/home_drawer_toggle_width"
                android:layout_height="@dimen/home_drawer_toggle_height"
                android:background="@drawable/bg_drawer_spinner"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMusicOn"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:text="@string/home_music_on"
                    android:textAllCaps="false"
                    android:textColor="@color/home_toggle_text"
                    android:textSize="@dimen/home_drawer_toggle_text_size"
                    android:textStyle="bold"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="@dimen/home_drawer_toggle_corner_radius"
                    app:rippleColor="@color/home_toggle_ripple" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMusicOff"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:text="@string/home_music_off"
                    android:textAllCaps="false"
                    android:textColor="@color/home_toggle_text"
                    android:textSize="@dimen/home_drawer_toggle_text_size"
                    android:textStyle="bold"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="@dimen/home_drawer_toggle_corner_radius"
                    app:rippleColor="@color/home_toggle_ripple" />
            </com.google.android.material.button.MaterialButtonToggleGroup>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/home_drawer_music_language_gap"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvDrawerLanguageLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="serif"
                android:text="@string/home_drawer_language"
                android:textColor="@color/home_drawer_text"
                android:textSize="@dimen/home_drawer_label_text_size"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/groupLanguage"
                android:layout_width="@dimen/home_drawer_toggle_width"
                android:layout_height="@dimen/home_drawer_toggle_height"
                android:background="@drawable/bg_drawer_spinner"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLangVi"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:text="@string/home_switch_to_vietnamese"
                    android:textAllCaps="false"
                    android:textColor="@color/home_toggle_text"
                    android:textSize="@dimen/home_drawer_lang_toggle_text_size"
                    android:textStyle="bold"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="@dimen/home_drawer_toggle_corner_radius"
                    app:rippleColor="@color/home_toggle_ripple" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnLangEn"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:text="@string/home_switch_to_english"
                    android:textAllCaps="false"
                    android:textColor="@color/home_toggle_text"
                    android:textSize="@dimen/home_drawer_lang_toggle_text_size"
                    android:textStyle="bold"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="@dimen/home_drawer_toggle_corner_radius"
                    app:rippleColor="@color/home_toggle_ripple" />
            </com.google.android.material.button.MaterialButtonToggleGroup>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/home_drawer_music_language_gap"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvDrawerThemeLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="serif"
                android:text="@string/home_drawer_theme"
                android:textColor="@color/home_drawer_text"
                android:textSize="@dimen/home_drawer_label_text_size"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/groupTheme"
                android:layout_width="@dimen/home_drawer_toggle_width"
                android:layout_height="@dimen/home_drawer_toggle_height"
                android:background="@drawable/bg_drawer_spinner"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnThemeLight"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:text="@string/home_theme_light"
                    android:textAllCaps="false"
                    android:textColor="@color/home_toggle_text"
                    android:textSize="@dimen/home_drawer_lang_toggle_text_size"
                    android:textStyle="bold"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="@dimen/home_drawer_toggle_corner_radius"
                    app:rippleColor="@color/home_toggle_ripple" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnThemeDark"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:text="@string/home_theme_dark"
                    android:textAllCaps="false"
                    android:textColor="@color/home_toggle_text"
                    android:textSize="@dimen/home_drawer_lang_toggle_text_size"
                    android:textStyle="bold"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="@dimen/home_drawer_toggle_corner_radius"
                    app:rippleColor="@color/home_toggle_ripple" />
            </com.google.android.material.button.MaterialButtonToggleGroup>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="@dimen/home_drawer_bottom_divider_margin_bottom"
            android:background="@color/home_drawer_divider" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDrawerSignOut"
            android:layout_width="@dimen/home_drawer_sign_out_width"
            android:layout_height="@dimen/home_drawer_sign_out_height"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/home_drawer_sign_out_margin_top"
            android:layout_marginBottom="@dimen/home_drawer_sign_out_margin_bottom"
            android:text="@string/auth_sign_out"
            android:textAllCaps="false"
            android:textColor="@android:color/black"
            android:textSize="@dimen/home_drawer_sign_out_text_size"
            android:textStyle="bold"
            app:backgroundTint="@color/history_pill_pink"
            app:cornerRadius="@dimen/home_drawer_sign_out_corner_radius" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>
