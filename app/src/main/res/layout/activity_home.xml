<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/homeContentRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_home_modern_gradient">

        <ImageView
            android:id="@+id/ivHomeBanner"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:contentDescription="@null"
            android:scaleType="centerCrop"
            android:src="@drawable/photo_banner"
            tools:ignore="ContentDescription"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <View
            android:id="@+id/viewHomeBannerDimmer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@drawable/bg_home_dark_scrim"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <LinearLayout
            android:id="@+id/topBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <FrameLayout
                android:id="@+id/btnMenu"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="@drawable/shape_glass_circle"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless">
                
                <ImageView
                    android:id="@+id/ivMenuIcon"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_menu_24"
                    app:tint="#FFFFFF" />
            </FrameLayout>

        </LinearLayout>

        <LinearLayout
            android:id="@+id/titleContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/topBar"
            app:layout_constraintBottom_toTopOf="@+id/mainContent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="0.25">

            <TextView
                android:id="@+id/tvHomeOur"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home_title_our"
                android:textColor="#FFFFFF"
                android:textSize="48sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.05"
                android:shadowColor="#80000000"
                android:shadowDx="0"
                android:shadowDy="4"
                android:shadowRadius="8" />

            <TextView
                android:id="@+id/tvHomeMemories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="-12dp"
                android:text="@string/home_title_memories"
                android:textColor="#FBBF24"
                android:textSize="56sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-black"
                android:letterSpacing="0.05"
                android:shadowColor="#80000000"
                android:shadowDx="0"
                android:shadowDy="4"
                android:shadowRadius="8" />

            <TextView
                android:id="@+id/tvHomePhotobooth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/home_title_photobooth"
                android:textColor="#E2E8F0"
                android:textSize="36sp"
                android:fontFamily="@font/pacifico_regular"
                android:shadowColor="#FF4081"
                android:shadowDx="0"
                android:shadowDy="0"
                android:shadowRadius="12" />

        </LinearLayout>

        <LinearLayout
            android:id="@+id/mainContent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_bias="0.85">

            <FrameLayout
                android:id="@+id/btnStart"
                android:layout_width="240dp"
                android:layout_height="64dp"
                android:background="@drawable/bg_home_start_button"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:elevation="8dp">
                
                <TextView
                    android:id="@+id/tvStartText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="✦ BẮT ĐẦU ✦"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />
            </FrameLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGallery"
                android:layout_width="240dp"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:text="@string/btn_gallery"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone"
                app:backgroundTint="#33FFFFFF"
                app:cornerRadius="28dp"
                app:elevation="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdmin"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="48dp"
                android:layout_marginTop="16dp"
                android:text="@string/admin_go_to_dashboard"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="14sp"
                android:visibility="gone"
                app:icon="@drawable/ic_settings_24"
                app:iconTint="@color/white"
                app:backgroundTint="#1AFFFFFF"
                app:cornerRadius="24dp" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

    <LinearLayout
        android:id="@+id/drawerPanel"
        android:layout_width="@dimen/admin_nav_drawer_width"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/home_drawer_bg"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/home_drawer_padding_horizontal"
        android:paddingTop="@dimen/home_drawer_padding_top"
        android:paddingBottom="@dimen/home_drawer_padding_bottom">

        <!-- ✦ Modern User Profile Header ✦ -->
        <LinearLayout
            android:id="@+id/cardNavUserProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_bottom_sheet_rounded"
            android:backgroundTint="#1AFFFFFF"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true">

            <!-- Avatar with Glow -->
            <FrameLayout
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:background="@drawable/shape_nav_avatar">
                
                <TextView
                    android:id="@+id/tvNavAvatarInitials"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="U"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivNavAvatar"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    app:shapeAppearanceOverlay="@style/CircleAppearance" />
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="14dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvNavUserName"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="User Name"
                    android:textColor="#FFFFFF"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:ellipsize="end"
                    android:maxLines="1" />

                <TextView
                    android:id="@+id/tvNavUserEmail"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="user@example.com"
                    android:textColor="#B0C4FF"
                    android:textSize="12sp"
                    android:ellipsize="end"
                    android:maxLines="1" />

                <TextView
                    android:id="@+id/tvNavUserRole"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_nav_role_pill"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="2dp"
                    android:text="Member"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_arrow_forward_24"
                app:tint="#40FFFFFF" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvDrawerNavLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ĐIỀU HƯỚNG"
            android:textColor="#4DFFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp"
            android:paddingStart="8dp" />

        <TextView
            android:id="@+id/tvDrawerShowHistory"
            android:layout_width="match_parent"
            android:layout_height="@dimen/home_drawer_item_height"
            android:layout_marginTop="@dimen/home_drawer_item_top_margin"
            android:background="@drawable/bg_drawer_item_clickable"
            android:drawableStart="@drawable/ic_grid_view_24"
            android:drawablePadding="@dimen/home_drawer_item_padding_horizontal"
            android:drawableTint="@color/home_drawer_text"
            android:fontFamily="serif"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/home_drawer_item_padding_horizontal"
            android:text="@string/home_drawer_show_history"
            android:textColor="@color/home_drawer_text"
            android:textSize="@dimen/home_drawer_item_text_size"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDrawerChangeBanner"
            android:layout_width="match_parent"
            android:layout_height="@dimen/home_drawer_item_height"
            android:layout_marginTop="@dimen/home_drawer_item_secondary_top_margin"
            android:background="@drawable/bg_drawer_item_clickable"
            android:drawableStart="@drawable/ic_image_24"
            android:drawablePadding="@dimen/home_drawer_item_padding_horizontal"
            android:drawableTint="@color/home_drawer_text"
            android:fontFamily="serif"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/home_drawer_item_padding_horizontal"
            android:text="@string/home_drawer_change_banner"
            android:textColor="@color/home_drawer_text"
            android:textSize="@dimen/home_drawer_item_text_size"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDrawerUsageGuide"
            android:layout_width="match_parent"
            android:layout_height="@dimen/home_drawer_item_height"
            android:layout_marginTop="@dimen/home_drawer_item_secondary_top_margin"
            android:background="@drawable/bg_drawer_item_clickable"
            android:drawableStart="@drawable/ic_help_24"
            android:drawablePadding="@dimen/home_drawer_item_padding_horizontal"
            android:drawableTint="@color/home_drawer_text"
            android:fontFamily="serif"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/home_drawer_item_padding_horizontal"
            android:text="@string/home_drawer_usage_guide"
            android:textColor="@color/home_drawer_text"
            android:textSize="@dimen/home_drawer_item_text_size"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDrawerAdminDashboard"
            android:layout_width="match_parent"
            android:layout_height="@dimen/home_drawer_item_height"
            android:layout_marginTop="@dimen/home_drawer_item_secondary_top_margin"
            android:background="@drawable/bg_drawer_item_clickable"
            android:drawableStart="@drawable/ic_settings_24"
            android:drawablePadding="@dimen/home_drawer_item_padding_horizontal"
            android:drawableTint="@color/home_drawer_text"
            android:fontFamily="serif"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/home_drawer_item_padding_horizontal"
            android:text="@string/admin_go_to_dashboard"
            android:textColor="@color/home_drawer_text"
            android:textSize="@dimen/home_drawer_item_text_size"
            android:textStyle="bold"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/home_drawer_section_top_margin"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvDrawerMusicLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="serif"
                android:text="@string/home_drawer_music"
                android:textColor="@color/home_drawer_text"
                android:textSize="@dimen/home_drawer_label_text_size"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/groupMusicState"
                android:layout_width="@dimen/home_drawer_toggle_width"
                android:layout_height="@dimen/home_drawer_toggle_height"
                android:background="@drawable/bg_drawer_spinner"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMusicOn"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="0dp"
                    app:icon="@drawable/ic_volume_up"
                    app:iconGravity="textTop"
                    app:iconPadding="0dp"
                    app:iconSize="22dp"
                    app:iconTint="@color/home_toggle_text"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="@dimen/home_drawer_toggle_corner_radius"
                    app:rippleColor="@color/home_toggle_ripple" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnMusicOff"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="0dp"
                    app:icon="@drawable/ic_volume_off"
                    app:iconGravity="textTop"
                    app:iconPadding="0dp"
                    app:iconSize="22dp"
                    app:iconTint="@color/home_toggle_text"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="@dimen/home_drawer_toggle_corner_radius"
                    app:rippleColor="@color/home_toggle_ripple" />
            </com.google.android.material.button.MaterialButtonToggleGroup>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/home_drawer_music_language_gap"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvDrawerThemeLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="serif"
                android:text="@string/home_drawer_theme"
                android:textColor="@color/home_drawer_text"
                android:textSize="@dimen/home_drawer_label_text_size"
                android:textStyle="bold" />

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/groupTheme"
                android:layout_width="@dimen/home_drawer_theme_toggle_width"
                android:layout_height="@dimen/home_drawer_toggle_height"
                android:background="@drawable/bg_drawer_spinner"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnThemeLight"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="0dp"
                    app:icon="@drawable/ic_theme_sun_20"
                    app:iconGravity="textTop"
                    app:iconPadding="0dp"
                    app:iconSize="22dp"
                    app:iconTint="@color/home_toggle_text"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="@dimen/home_drawer_toggle_corner_radius"
                    app:rippleColor="@color/home_toggle_ripple" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnThemeDark"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="0dp"
                    app:icon="@drawable/ic_theme_moon_20"
                    app:iconGravity="textTop"
                    app:iconPadding="0dp"
                    app:iconSize="22dp"
                    app:iconTint="@color/home_toggle_text"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="@dimen/home_drawer_toggle_corner_radius"
                    app:rippleColor="@color/home_toggle_ripple" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnThemeSystem"
                    style="@style/Widget.MaterialComponents.Button.TextButton"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:minWidth="0dp"
                    android:minHeight="0dp"
                    android:padding="0dp"
                    app:icon="@drawable/ic_auto_awesome"
                    app:iconGravity="textTop"
                    app:iconPadding="0dp"
                    app:iconSize="22dp"
                    app:iconTint="@color/home_toggle_text"
                    app:backgroundTint="@android:color/transparent"
                    app:cornerRadius="@dimen/home_drawer_toggle_corner_radius"
                    app:rippleColor="@color/home_toggle_ripple" />
            </com.google.android.material.button.MaterialButtonToggleGroup>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/home_drawer_music_language_gap"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tvDrawerLanguageLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="serif"
                android:text="@string/home_drawer_language"
                android:textColor="@color/home_drawer_text"
                android:textSize="@dimen/home_drawer_label_text_size"
                android:textStyle="bold" />

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/btnLanguageToggle"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:src="@drawable/ic_flag_vn"
                android:scaleType="centerCrop"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                app:shapeAppearanceOverlay="@style/CircleAppearance" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginBottom="@dimen/home_drawer_bottom_divider_margin_bottom"
            android:background="@color/home_drawer_divider" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDrawerSignOut"
            android:layout_width="@dimen/home_drawer_sign_out_width"
            android:layout_height="@dimen/home_drawer_sign_out_height"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="@dimen/home_drawer_sign_out_margin_top"
            android:layout_marginBottom="@dimen/home_drawer_sign_out_margin_bottom"
            android:text="@string/auth_sign_out"
            android:textAllCaps="false"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/home_drawer_sign_out_text_size"
            android:textStyle="bold"
            app:backgroundTint="@color/history_pill_pink"
            app:cornerRadius="@dimen/home_drawer_sign_out_corner_radius" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>

