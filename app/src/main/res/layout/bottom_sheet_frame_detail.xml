<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet_rounded"
    android:paddingBottom="32dp">

    <!-- Drag handle -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:background="#1A2A6C"
        android:alpha="0.2"/>

    <!-- Frame preview card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="12dp"
        app:cardCornerRadius="20dp"
        app:cardElevation="8dp"
        app:strokeWidth="0dp">

        <ImageView
            android:id="@+id/bsIvFrame"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="centerCrop"/>

    </com.google.android.material.card.MaterialCardView>

    <!-- Label badge -->
    <TextView
        android:id="@+id/bsTvLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="20dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:background="@drawable/bg_tag_primary"
        android:textColor="#FFFFFF"
        android:textSize="17sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"/>

    <!-- Info cards container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="20dp"
        android:gravity="center">

        <!-- Layout type card -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/bg_info_chip"
            android:layout_marginEnd="8dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📐 Layout"
                android:textColor="#8895B3"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"/>

            <TextView
                android:id="@+id/bsTvLayout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="#1B2A5C"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <!-- Slot count card -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/bg_info_chip"
            android:layout_marginStart="8dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🖼 Số ảnh"
                android:textColor="#8895B3"
                android:textSize="11sp"
                android:textAllCaps="true"
                android:letterSpacing="0.08"/>

            <TextView
                android:id="@+id/bsTvSlotCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="#1B2A5C"
                android:textSize="14sp"
                android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Upload date row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="12dp"
        android:padding="16dp"
        android:background="@drawable/bg_info_chip"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🕒 Ngày tải lên"
            android:textColor="#8895B3"
            android:textSize="13sp"/>

        <TextView
            android:id="@+id/bsTvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#1B2A5C"
            android:textSize="13sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Frame ID row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="8dp"
        android:padding="16dp"
        android:background="@drawable/bg_info_chip"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🔑 Frame ID"
            android:textColor="#8895B3"
            android:textSize="13sp"/>

        <TextView
            android:id="@+id/bsTvId"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#6B7A99"
            android:textSize="12sp"
            android:fontFamily="monospace"/>
    </LinearLayout>

    <!-- Close button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/bsBtnClose"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginTop="24dp"
        android:text="Đóng"
        android:textColor="@color/white"
        android:textSize="15sp"
        android:textStyle="bold"
        app:backgroundTint="#1A2A6C"
        app:cornerRadius="16dp"
        app:icon="@android:drawable/ic_menu_close_clear_cancel"
        app:iconGravity="textStart"
        app:iconTint="@color/white"/>

</LinearLayout>
