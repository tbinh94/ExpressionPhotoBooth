<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background from Homepage -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/photo_banner" />

    <!-- Dark overlay to ensure text readability -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#812C2A2A" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/btnLanguageToggle"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="54dp"
        android:layout_marginEnd="16dp"
        android:src="@drawable/ic_flag_vn"
        android:scaleType="centerCrop"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        app:shapeAppearanceOverlay="@style/CircleAppearance"
        app:strokeColor="#80FFFFFF"
        app:strokeWidth="1dp" />

    <!-- Logo / App branding at top -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="64dp"
        android:gravity="center"
        android:orientation="vertical"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardLogin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:cardBackgroundColor="@color/surface_card"
        app:cardCornerRadius="36dp"
        app:cardElevation="24dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="36dp"
                android:paddingBottom="0dp">

                <TextView
                    android:id="@+id/tvLoginTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/auth_title"
                    android:textColor="@color/text_primary"
                    android:textSize="25sp"
                    android:letterSpacing="-0.01"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvLoginSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/auth_subtitle"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="2dp" />

                <View
                    android:layout_width="40dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/shape_accent_line" />
            </LinearLayout>

            <!-- FORM -->
            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="480dp"
                android:overScrollMode="ifContentScrolls"
                android:fillViewport="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="28dp"
                    android:paddingEnd="28dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="32dp">

                    <!-- Register extra fields -->
                    <LinearLayout
                        android:id="@+id/layoutRegisterExtra"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="@string/auth_name"
                            app:boxCornerRadiusBottomEnd="16dp"
                            app:boxCornerRadiusBottomStart="16dp"
                            app:boxCornerRadiusTopEnd="16dp"
                            app:boxCornerRadiusTopStart="16dp"
                            app:boxStrokeColor="@color/color_input_stroke"
                            app:boxStrokeWidth="1.5dp"
                            app:hintTextColor="@color/camera_mode_primary"
                            app:startIconDrawable="@drawable/ic_person_24"
                            app:startIconTint="@color/camera_mode_primary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPersonName"
                                android:maxLines="1"
                                android:textColor="@color/text_primary"
                                android:textColorHint="@color/text_secondary"
                                android:textSize="15sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="@string/auth_birthday"
                            app:boxCornerRadiusBottomEnd="16dp"
                            app:boxCornerRadiusBottomStart="16dp"
                            app:boxCornerRadiusTopEnd="16dp"
                            app:boxCornerRadiusTopStart="16dp"
                            app:boxStrokeColor="@color/color_input_stroke"
                            app:boxStrokeWidth="1.5dp"
                            app:hintTextColor="@color/camera_mode_primary"
                            app:startIconDrawable="@drawable/ic_calendar_24"
                            app:startIconTint="@color/camera_mode_primary"
                            app:endIconMode="custom"
                            app:endIconDrawable="@drawable/ic_help_24"
                            app:endIconTint="@color/text_secondary">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etBirthday"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:focusable="false"
                                android:inputType="none"
                                android:textColor="@color/text_primary"
                                android:textColorHint="@color/text_secondary"
                                android:textSize="15sp" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- Email -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/auth_email"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxStrokeColor="@color/color_input_stroke"
                        app:boxStrokeWidth="1.5dp"
                        app:hintTextColor="@color/camera_mode_primary"
                        app:startIconDrawable="@drawable/ic_email_24"
                        app:startIconTint="@color/camera_mode_primary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textEmailAddress"
                            android:maxLines="1"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary"
                            android:textSize="15sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Password -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/auth_password"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxStrokeColor="@color/color_input_stroke"
                        app:boxStrokeWidth="1.5dp"
                        app:hintTextColor="@color/camera_mode_primary"
                        app:startIconDrawable="@drawable/ic_lock_24"
                        app:startIconTint="@color/camera_mode_primary"
                        app:endIconMode="password_toggle">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:maxLines="1"
                            android:textColor="@color/text_primary"
                            android:textColorHint="@color/text_secondary"
                            android:textSize="15sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Forgot password -->
                    <TextView
                        android:id="@+id/tvForgotPassword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="10dp"
                        android:layout_marginEnd="2dp"
                        android:text="@string/auth_forgot_password"
                        android:textColor="@color/camera_mode_primary"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true" />

                    <!-- Main Button (Sign In or Confirm Register) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSignIn"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="20dp"
                        android:text="@string/auth_sign_in"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.04"
                        app:backgroundTint="@color/camera_mode_primary"
                        app:cornerRadius="27dp"
                        app:elevation="6dp"
                        app:icon="@drawable/ic_login_24"
                        app:iconGravity="textStart"
                        app:iconTint="#FFFFFF"
                        app:iconPadding="8dp" />

                    <!-- OR divider -->
                    <LinearLayout
                        android:id="@+id/layoutOrDivider"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"
                            android:background="@color/screen_divider" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="12dp"
                            android:text="@string/auth_or"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.1" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"
                            android:background="@color/screen_divider" />
                    </LinearLayout>

                    <!-- Google Sign In Button -->
                    <androidx.cardview.widget.CardView
                        android:id="@+id/btnGoogleSignIn"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="16dp"
                        android:clickable="true"
                        android:focusable="true"
                        android:foreground="?attr/selectableItemBackground"
                        app:cardBackgroundColor="#FFFFFF"
                        app:cardCornerRadius="27dp"
                        app:cardElevation="3dp"
                        app:strokeColor="#E0E0E0"
                        app:strokeWidth="1dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:paddingStart="16dp"
                            android:paddingEnd="16dp">

                            <ImageView
                                android:id="@+id/ivGoogleIcon"
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:layout_alignParentStart="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/ic_google_logo"
                                android:scaleType="fitCenter" />

                            <TextView
                                android:id="@+id/tvGoogleSignInLabel"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerInParent="true"
                                android:text="@string/auth_google_sign_in"
                                android:textColor="#3C4043"
                                android:textSize="15sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-medium"
                                android:letterSpacing="0.01" />

                        </RelativeLayout>
                    </androidx.cardview.widget.CardView>

                    <!-- Secondary Button (Go to Register or Back to Login) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRegister"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="14dp"
                        android:text="@string/auth_register"
                        android:textAllCaps="false"
                        android:textColor="@color/camera_mode_primary"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:cornerRadius="27dp"
                        app:strokeColor="@color/camera_mode_primary"
                        app:strokeWidth="1.5dp"
                        app:icon="@drawable/ic_person_add_24"
                        app:iconGravity="textStart"
                        app:iconTint="@color/camera_mode_primary"
                        app:iconPadding="8dp" />

                    <!-- Guest button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGuest"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:text="@string/auth_sign_in_as_guest"
                        android:textAllCaps="false"
                        android:textColor="@color/text_secondary"
                        android:textSize="14sp"
                        app:cornerRadius="24dp"
                        app:icon="@drawable/ic_person_outline_24"
                        app:iconGravity="textStart"
                        app:iconTint="@color/text_secondary"
                        app:iconPadding="8dp" />

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>


    <!-- Loading Overlay - Redesigned -->
    <FrameLayout
        android:id="@+id/layoutLoadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#BF000000"
        android:clickable="true"
        android:focusable="true"
        android:elevation="100dp"
        android:visibility="gone">

        <androidx.cardview.widget.CardView
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:cardBackgroundColor="@color/surface_card"
            app:cardCornerRadius="28dp"
            app:cardElevation="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="36dp"
                android:paddingBottom="32dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:indeterminate="true"
                    app:indicatorColor="@array/loading_indicator_colors"
                    app:indicatorSize="72dp"
                    app:trackThickness="7dp"
                    app:trackColor="@color/screen_divider"
                    app:trackCornerRadius="10dp" />

                <TextView
                    android:id="@+id/tvLoadingMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/auth_loading"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Vui lòng đợi trong giây lát"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:lineSpacingExtra="2dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

