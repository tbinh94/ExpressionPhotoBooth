<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Background from Homepage -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/photo_banner" />

    <!-- Dark overlay to ensure text readability -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#812C2A2A" />

    <!-- Language Toggle -->
    <FrameLayout
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="54dp"
        android:layout_marginEnd="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLanguageToggle"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:insetLeft="0dp"
            android:insetTop="0dp"
            android:insetRight="0dp"
            android:insetBottom="0dp"
            android:padding="0dp"
            android:gravity="center"
            android:contentDescription="@string/language_toggle_to_english"
            app:cornerRadius="16dp"
            app:backgroundTint="#40FFFFFF"
            app:icon="@drawable/ic_language_24"
            app:iconGravity="textTop"
            app:iconPadding="0dp"
            app:iconSize="22dp"
            app:iconTint="@color/white"
            app:strokeColor="#80FFFFFF"
            app:strokeWidth="1dp" />

        <TextView
            android:id="@+id/tvLanguageBadge"
            android:layout_width="18dp"
            android:layout_height="14dp"
            android:layout_gravity="end|top"
            android:layout_marginEnd="-2dp"
            android:layout_marginTop="-2dp"
            android:background="@drawable/bg_language_badge"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="EN"
            android:textColor="@color/white"
            android:textSize="8sp"
            android:textStyle="bold" />
    </FrameLayout>

    <!-- Logo / App branding at top -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="64dp"
        android:gravity="center"
        android:orientation="vertical"/>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardLogin"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:cardBackgroundColor="#ffffff"
        app:cardCornerRadius="36dp"
        app:cardElevation="24dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="28dp"
                android:paddingEnd="28dp"
                android:paddingTop="36dp"
                android:paddingBottom="0dp">

                <TextView
                    android:id="@+id/tvLoginTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/auth_title"
                    android:textColor="#2A5197"
                    android:textSize="25sp"
                    android:letterSpacing="-0.01"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvLoginSubtitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="@string/auth_subtitle"
                    android:textColor="#B3B3B3"
                    android:textSize="14sp"
                    android:lineSpacingExtra="2dp" />

                <View
                    android:layout_width="40dp"
                    android:layout_height="3dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/shape_accent_line" />
            </LinearLayout>

            <!-- FORM -->
            <androidx.core.widget.NestedScrollView
                android:layout_width="match_parent"
                android:layout_height="480dp"
                android:overScrollMode="ifContentScrolls"
                android:fillViewport="false">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingStart="28dp"
                    android:paddingEnd="28dp"
                    android:paddingTop="8dp"
                    android:paddingBottom="32dp">

                    <!-- Register extra fields -->
                    <LinearLayout
                        android:id="@+id/layoutRegisterExtra"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:visibility="gone">

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="@string/auth_name"
                            app:boxCornerRadiusBottomEnd="16dp"
                            app:boxCornerRadiusBottomStart="16dp"
                            app:boxCornerRadiusTopEnd="16dp"
                            app:boxCornerRadiusTopStart="16dp"
                            app:boxStrokeColor="@color/color_input_stroke"
                            app:boxStrokeWidth="1.5dp"
                            app:hintTextColor="#2A5298"
                            app:startIconDrawable="@drawable/ic_person_24"
                            app:startIconTint="#2A5298">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etName"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="textPersonName"
                                android:maxLines="1"
                                android:textColor="#0D1B3E"
                                android:textColorHint="#A8B8CC"
                                android:textSize="15sp" />
                        </com.google.android.material.textfield.TextInputLayout>

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:hint="@string/auth_birthday"
                            app:boxCornerRadiusBottomEnd="16dp"
                            app:boxCornerRadiusBottomStart="16dp"
                            app:boxCornerRadiusTopEnd="16dp"
                            app:boxCornerRadiusTopStart="16dp"
                            app:boxStrokeColor="@color/color_input_stroke"
                            app:boxStrokeWidth="1.5dp"
                            app:hintTextColor="#2A5298"
                            app:startIconDrawable="@drawable/ic_calendar_24"
                            app:startIconTint="#2A5298"
                            app:endIconMode="custom"
                            app:endIconDrawable="@drawable/ic_help_24"
                            app:endIconTint="#7A8FA8">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/etBirthday"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:focusable="false"
                                android:inputType="none"
                                android:textColor="#0D1B3E"
                                android:textColorHint="#A8B8CC"
                                android:textSize="15sp" />
                        </com.google.android.material.textfield.TextInputLayout>
                    </LinearLayout>

                    <!-- Email -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/auth_email"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxStrokeColor="@color/color_input_stroke"
                        app:boxStrokeWidth="1.5dp"
                        app:hintTextColor="#2A5197"
                        app:startIconDrawable="@drawable/ic_email_24"
                        app:startIconTint="#2A5197">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textEmailAddress"
                            android:maxLines="1"
                            android:textColor="#0D1B3E"
                            android:textColorHint="#D5D8E4"
                            android:textSize="15sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Password -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:hint="@string/auth_password"
                        app:boxCornerRadiusBottomEnd="16dp"
                        app:boxCornerRadiusBottomStart="16dp"
                        app:boxCornerRadiusTopEnd="16dp"
                        app:boxCornerRadiusTopStart="16dp"
                        app:boxStrokeColor="@color/color_input_stroke"
                        app:boxStrokeWidth="1.5dp"
                        app:hintTextColor="#2A5298"
                        app:startIconDrawable="@drawable/ic_lock_24"
                        app:startIconTint="#2A5298"
                        app:endIconMode="password_toggle">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etPassword"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:maxLines="1"
                            android:textColor="#0D1B3E"
                            android:textColorHint="#A8B8CC"
                            android:textSize="15sp" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Forgot password -->
                    <TextView
                        android:id="@+id/tvForgotPassword"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="end"
                        android:layout_marginTop="10dp"
                        android:layout_marginEnd="2dp"
                        android:text="@string/auth_forgot_password"
                        android:textColor="#2A5298"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:clickable="true"
                        android:focusable="true" />

                    <!-- Main Button (Sign In or Confirm Register) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnSignIn"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="20dp"
                        android:text="@string/auth_sign_in"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.04"
                        app:backgroundTint="#2A5298"
                        app:cornerRadius="27dp"
                        app:elevation="6dp"
                        app:icon="@drawable/ic_login_24"
                        app:iconGravity="textStart"
                        app:iconTint="#FFFFFF"
                        app:iconPadding="8dp" />

                    <!-- OR divider -->
                    <LinearLayout
                        android:id="@+id/layoutOrDivider"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"
                            android:background="#E0E8F4" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="12dp"
                            android:text="@string/auth_or"
                            android:textColor="#B0BECF"
                            android:textSize="12sp"
                            android:textAllCaps="true"
                            android:letterSpacing="0.1" />

                        <View
                            android:layout_width="0dp"
                            android:layout_height="1dp"
                            android:layout_weight="1"
                            android:background="#E0E8F4" />
                    </LinearLayout>

                    <!-- Secondary Button (Go to Register or Back to Login) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRegister"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="14dp"
                        android:text="@string/auth_register"
                        android:textAllCaps="false"
                        android:textColor="#2A5298"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        app:cornerRadius="27dp"
                        app:strokeColor="#2A5298"
                        app:strokeWidth="1.5dp"
                        app:icon="@drawable/ic_person_add_24"
                        app:iconGravity="textStart"
                        app:iconTint="#2A5298"
                        app:iconPadding="8dp" />

                    <!-- Guest button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGuest"
                        style="@style/Widget.MaterialComponents.Button.TextButton"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="6dp"
                        android:text="@string/auth_sign_in_as_guest"
                        android:textAllCaps="false"
                        android:textColor="#7A8FA8"
                        android:textSize="14sp"
                        app:cornerRadius="24dp"
                        app:icon="@drawable/ic_person_outline_24"
                        app:iconGravity="textStart"
                        app:iconTint="#7A8FA8"
                        app:iconPadding="8dp" />

                </LinearLayout>
            </androidx.core.widget.NestedScrollView>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>


    <!-- Loading Overlay - Redesigned -->
    <FrameLayout
        android:id="@+id/layoutLoadingOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#BF000000"
        android:clickable="true"
        android:focusable="true"
        android:elevation="100dp"
        android:visibility="gone">

        <androidx.cardview.widget.CardView
            android:layout_width="220dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            app:cardBackgroundColor="#FFFFFF"
            app:cardCornerRadius="28dp"
            app:cardElevation="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="36dp"
                android:paddingBottom="32dp"
                android:paddingStart="24dp"
                android:paddingEnd="24dp">

                <com.google.android.material.progressindicator.CircularProgressIndicator
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:indeterminate="true"
                    app:indicatorColor="@array/loading_indicator_colors"
                    app:indicatorSize="72dp"
                    app:trackThickness="7dp"
                    app:trackColor="#E0E8F4"
                    app:trackCornerRadius="10dp" />

                <TextView
                    android:id="@+id/tvLoadingMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/auth_loading"
                    android:textColor="#0D1B3E"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.02"
                    android:gravity="center" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Vui lòng đợi trong giây lát"
                    android:textColor="#7A8FA8"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:lineSpacingExtra="2dp" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
