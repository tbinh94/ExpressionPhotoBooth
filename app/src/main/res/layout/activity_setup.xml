<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_bg">

    <ImageView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_screen_dynamic"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBack"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="@dimen/setup_top_action_size"
        android:layout_height="@dimen/setup_top_action_size"
        android:layout_marginStart="@dimen/setup_top_action_margin_horizontal"
        android:layout_marginTop="@dimen/setup_top_action_margin_top"
        app:icon="@drawable/ic_arrow_back_24"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconSize="24dp"
        app:iconTint="@color/screen_icon_tint"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:cornerRadius="24dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnHelpSetup"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="@dimen/setup_top_action_size"
        android:layout_height="@dimen/setup_top_action_size"
        android:layout_marginTop="@dimen/setup_top_action_margin_top"
        android:layout_marginEnd="@dimen/setup_top_action_margin_horizontal"
        android:contentDescription="@string/help_setup_content_desc"
        app:icon="@drawable/ic_help_24"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:iconSize="24dp"
        app:iconTint="@color/screen_icon_tint"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:cornerRadius="24dp" />

    <!-- HEADING SECTION -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/setup_title"
        android:fontFamily="@font/pacifico_regular"
        android:textColor="@color/screen_title"
        android:textSize="32sp"
        android:textStyle="bold"
        android:shadowColor="@color/screen_title_shadow"
        android:shadowDx="2"
        android:shadowDy="2"
        android:shadowRadius="8"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="0dp"
        android:text="@string/setup_subtitle"
        android:textColor="@color/screen_subtitle"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- PHẦN CHỈ ĐỊNH CUỘN: RecyclerView -->
    <!-- Quan trọng: layout_height="0dp" để nó chiếm khoảng không ở giữa và tự scroll -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvConcepts"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/setup_list_margin_top"
        android:layout_marginBottom="@dimen/setup_list_margin_bottom"
        android:clipToPadding="false"
        android:paddingBottom="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvSubtitle"
        app:layout_constraintBottom_toTopOf="@id/btnNext"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- PHẦN CỐ ĐỊNH PHÍA DƯỚI -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNext"
        android:layout_width="@dimen/setup_next_width"
        android:layout_height="@dimen/setup_next_height"
        android:layout_marginBottom="@dimen/setup_next_margin_bottom"
        android:text="@string/btn_next_decorated"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold"
        app:backgroundTint="@color/history_pill_pink"
        app:cornerRadius="28dp"
        app:elevation="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
