<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp">

    <ImageView
        android:id="@+id/ivStampBorder"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:scaleType="fitXY"
        android:src="@drawable/bg_stamp_border"
        app:layout_constraintDimensionRatio="3:4"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/ivGalleryPhoto"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="12dp"
        android:scaleType="centerCrop"
        app:layout_constraintBottom_toBottomOf="@id/ivStampBorder"
        app:layout_constraintEnd_toEndOf="@id/ivStampBorder"
        app:layout_constraintStart_toStartOf="@id/ivStampBorder"
        app:layout_constraintTop_toTopOf="@id/ivStampBorder" />

    <!-- X Delete button - top right corner of stamp -->
    <ImageButton
        android:id="@+id/btnDeletePhoto"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="4dp"
        android:background="@drawable/bg_delete_btn"
        android:src="@drawable/ic_delete_24"
        android:scaleType="centerInside"
        android:padding="4dp"
        android:elevation="4dp"
        android:visibility="gone"
        app:tint="#FFFFFF"
        app:layout_constraintEnd_toEndOf="@id/ivStampBorder"
        app:layout_constraintTop_toTopOf="@id/ivStampBorder" />

    <ImageView
        android:id="@+id/ivPlayIcon"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:src="@drawable/ic_movie_24"
        android:visibility="gone"
        android:alpha="0.8"
        app:tint="#FFFFFF"
        app:layout_constraintTop_toTopOf="@id/ivGalleryPhoto"
        app:layout_constraintBottom_toBottomOf="@id/ivGalleryPhoto"
        app:layout_constraintStart_toStartOf="@id/ivGalleryPhoto"
        app:layout_constraintEnd_toEndOf="@id/ivGalleryPhoto" />

    <TextView
        android:id="@+id/tvDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:alpha="0.78"
        android:fontFamily="serif"
        android:textColor="@color/text_secondary"
        android:textSize="10sp"
        app:layout_constraintEnd_toEndOf="@id/ivStampBorder"
        app:layout_constraintStart_toStartOf="@id/ivStampBorder"
        app:layout_constraintTop_toBottomOf="@id/ivStampBorder" />

    <!-- Selection Overlay & Checkbox -->
    <View
        android:id="@+id/selectionOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#4D000000"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/ivGalleryPhoto"
        app:layout_constraintBottom_toBottomOf="@id/ivGalleryPhoto"
        app:layout_constraintStart_toStartOf="@id/ivGalleryPhoto"
        app:layout_constraintEnd_toEndOf="@id/ivGalleryPhoto" />

    <ImageView
        android:id="@+id/ivSelectionCheck"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:layout_margin="8dp"
        android:src="@drawable/ic_check_circle_24"
        android:visibility="gone"
        app:tint="@color/app_blue"
        app:layout_constraintBottom_toBottomOf="@id/ivGalleryPhoto"
        app:layout_constraintEnd_toEndOf="@id/ivGalleryPhoto" />

</androidx.constraintlayout.widget.ConstraintLayout>
