<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#2A57B0"
                android:endColor="#214690" />
            <stroke android:width="1dp" android:color="#9BC0FF" />
            <corners android:radius="18dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="90"
                android:startColor="#4F84FF"
                android:endColor="#2F62D6" />
            <stroke android:width="1dp" android:color="#B6D0FF" />
            <corners android:radius="18dp" />
        </shape>
    </item>
</selector>


